@page
@model global::Aero.Cms.Modules.Setup.Areas.MyFeature.Pages.SetupModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    if (System.Diagnostics.Debugger.IsAttached && HttpContext.Request.Method == "GET")
    {
        Model.Input.Password = "*strongPassword1";
        Model.Input.ConfirmPassword = "*strongPassword1";
    }


    string FieldClass(string key)
    {
        var hasError = ViewData.ModelState.TryGetValue(key, out var entry) && entry.Errors.Count > 0;

        return hasError
            ? "mt-2 block w-full rounded-2xl border border-rose-300 bg-white/95 px-4 py-3.5 text-sm text-slate-900 shadow-sm outline-none ring-4 ring-rose-100 transition placeholder:text-slate-400"
            : "mt-2 block w-full rounded-2xl border border-slate-200 bg-white/95 px-4 py-3.5 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-cyan-400 focus:ring-4 focus:ring-cyan-100";
    }
}
<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>Aero CMS Setup</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        aero: {
                            ink: "#0f172a",
                            mist: "#e2e8f0",
                            cloud: "#f8fafc",
                            cyan: "#0f766e",
                            gold: "#f59e0b"
                        }
                    },
                    fontFamily: {
                        sans: ["Manrope", "ui-sans-serif", "sans-serif"],
                        display: ["Fraunces", "ui-serif", "serif"]
                    },
                    boxShadow: {
                        panel: "0 24px 80px rgba(15, 23, 42, 0.14)"
                    }
                }
            }
        };
    </script>
</head>
<body class="min-h-full bg-[radial-gradient(circle_at_top_left,_rgba(15,118,110,0.18),_transparent_32%),radial-gradient(circle_at_bottom_right,_rgba(245,158,11,0.16),_transparent_28%),linear-gradient(180deg,_#f8fafc_0%,_#eef2ff_42%,_#f8fafc_100%)] font-sans text-slate-900 antialiased">
    <div class="relative isolate overflow-hidden">
        <div class="absolute inset-x-0 top-0 -z-10 h-40 bg-[linear-gradient(135deg,_rgba(15,23,42,0.96),_rgba(15,23,42,0.72),_rgba(15,118,110,0.52))]"></div>
        <div class="absolute left-1/2 top-20 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-cyan-300/20 blur-3xl"></div>

        <main class="mx-auto flex min-h-screen max-w-7xl items-center px-6 py-10 lg:px-8">
            <div class="grid w-full gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(22rem,34rem)] lg:items-center">
                <section class="max-w-2xl text-slate-950">
                    <span class="inline-flex items-center rounded-full border border-white/50 bg-white/70 px-4 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-slate-600 shadow-sm backdrop-blur">Aero CMS bootstrap</span>
                    <h1 class="mt-6 max-w-xl font-display text-4xl leading-tight text-slate-950 sm:text-5xl">Shape the first admin experience before your content model wakes up.</h1>
                    <p class="mt-5 max-w-xl text-base leading-7 text-slate-600 sm:text-lg">Capture the account details and starter site metadata the CMS will use for first-run provisioning. This pass bootstraps the initial administrator through ASP.NET Core Identity managers, keeps redirects local, and leaves content seeding for the next task.</p>

                    <div class="mt-8 grid gap-4 sm:grid-cols-3">
                        <div class="rounded-3xl border border-white/70 bg-white/75 p-5 shadow-lg shadow-slate-900/5 backdrop-blur">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Access</p>
                            <p class="mt-3 text-lg font-semibold text-slate-900">First administrator</p>
                            <p class="mt-2 text-sm leading-6 text-slate-600">Username, email, and password are validated server-side before anything mutates.</p>
                        </div>
                        <div class="rounded-3xl border border-white/70 bg-white/75 p-5 shadow-lg shadow-slate-900/5 backdrop-blur">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Seed copy</p>
                            <p class="mt-3 text-lg font-semibold text-slate-900">Starter site metadata</p>
                            <p class="mt-2 text-sm leading-6 text-slate-600">Site, homepage, and blog titles are collected now so the next setup task can seed content deterministically.</p>
                        </div>
                        <div class="rounded-3xl border border-white/70 bg-white/75 p-5 shadow-lg shadow-slate-900/5 backdrop-blur">
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Safety</p>
                            <p class="mt-3 text-lg font-semibold text-slate-900">Local redirects only</p>
                            <p class="mt-2 text-sm leading-6 text-slate-600">Any external `returnUrl` is ignored so the setup surface cannot become an open redirect.</p>
                        </div>
                    </div>
                </section>

                <section class="rounded-[2rem] border border-white/70 bg-white/85 p-6 shadow-panel backdrop-blur xl:p-8">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-aero-cyan">Setup workspace</p>
                            <h2 class="mt-2 text-2xl font-semibold text-slate-950">Configure the first-run command</h2>
                            <p class="mt-2 text-sm leading-6 text-slate-500">Invalid submissions stay here with inline guidance. Valid submissions redirect only to a local target.</p>
                        </div>
                        <div class="hidden rounded-2xl border border-amber-200 bg-amber-50 px-3 py-2 text-right text-xs font-medium text-amber-700 sm:block">
                            Tailwind surface
                            <div class="text-[11px] font-normal text-amber-600">inside the setup module</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                    {
                        <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">
                            @Model.StatusMessage
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="mt-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                            <p class="font-semibold text-rose-800">Review the highlighted fields before continuing.</p>
                            <div asp-validation-summary="ModelOnly" class="mt-2 space-y-1"></div>
                        </div>
                    }

                    <form method="post" novalidate class="mt-6 space-y-8">
                        <input asp-for="ReturnUrl" type="hidden" />

                        <div class="space-y-5">
                            <div class="flex items-center gap-3">
                                <div class="h-px flex-1 bg-slate-200"></div>
                                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Administrator access</p>
                                <div class="h-px flex-1 bg-slate-200"></div>
                            </div>

                            <div class="grid gap-5 sm:grid-cols-2">
                                <div class="sm:col-span-2">
                                    <label asp-for="Input.AdminUserName" class="text-sm font-semibold text-slate-800"></label>
                                    <input asp-for="Input.AdminUserName" autocomplete="username" class="@FieldClass("Input.AdminUserName")" placeholder="founder" />
                                    <span asp-validation-for="Input.AdminUserName" class="mt-2 block text-sm font-medium text-rose-600"></span>
                                </div>

                                <div class="sm:col-span-2">
                                    <label asp-for="Input.AdminEmail" class="text-sm font-semibold text-slate-800"></label>
                                    <input asp-for="Input.AdminEmail" autocomplete="email" class="@FieldClass("Input.AdminEmail")" placeholder="admin@example.com" />
                                    <span asp-validation-for="Input.AdminEmail" class="mt-2 block text-sm font-medium text-rose-600"></span>
                                </div>

                                <div x-data="{ show: false }">
                                    <label asp-for="Input.Password" class="text-sm font-semibold text-slate-800"></label>
                                    <div class="relative">
                                        <input asp-for="Input.Password" :type="show ? 'text' : 'password'" value="@Model.Input.Password" autocomplete="new-password" class="@FieldClass("Input.Password") pr-12" placeholder="At least 12 characters" />
                                        <button type="button" @@click="show = !show" class="absolute right-3 top-1/2 mt-1 -translate-y-1/2 rounded-lg p-1 text-slate-400 hover:text-slate-600 focus:outline-none">
                                            <svg x-show="!show" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.413 8.134 7.378 5 12 5c4.622 0 8.587 3.134 9.964 7.322a1.012 1.012 0 010 .644C20.587 15.866 16.622 19 12 19c-4.622 0-8.587-3.134-9.964-7.322z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            </svg>
                                            <svg x-show="show" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" style="display:none">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.822 7.822L21 21m-2.278-2.278L15.07 15.07M9.172 9.172L7.336 7.336M9.172 9.172a4 4 0 105.656 5.656m-5.656-5.656l5.656 5.656" />
                                            </svg>
                                        </button>
                                    </div>
                                    <span asp-validation-for="Input.Password" class="mt-2 block text-sm font-medium text-rose-600"></span>
                                </div>

                                <div x-data="{ show: false }">
                                    <label asp-for="Input.ConfirmPassword" class="text-sm font-semibold text-slate-800"></label>
                                    <div class="relative">
                                        <input asp-for="Input.ConfirmPassword" :type="show ? 'text' : 'password'" value="@Model.Input.ConfirmPassword" autocomplete="new-password" class="@FieldClass("Input.ConfirmPassword") pr-12" placeholder="Repeat the password" />
                                        <button type="button" @@click="show = !show" class="absolute right-3 top-1/2 mt-1 -translate-y-1/2 rounded-lg p-1 text-slate-400 hover:text-slate-600 focus:outline-none">
                                            <svg x-show="!show" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.644C3.413 8.134 7.378 5 12 5c4.622 0 8.587 3.134 9.964 7.322a1.012 1.012 0 010 .644C20.587 15.866 16.622 19 12 19c-4.622 0-8.587-3.134-9.964-7.322z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            </svg>
                                            <svg x-show="show" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" style="display:none">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.822 7.822L21 21m-2.278-2.278L15.07 15.07M9.172 9.172L7.336 7.336M9.172 9.172a4 4 0 105.656 5.656m-5.656-5.656l5.656 5.656" />
                                            </svg>
                                        </button>
                                    </div>
                                    <span asp-validation-for="Input.ConfirmPassword" class="mt-2 block text-sm font-medium text-rose-600"></span>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-5">
                            <div class="flex items-center gap-3">
                                <div class="h-px flex-1 bg-slate-200"></div>
                                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Starter site metadata</p>
                                <div class="h-px flex-1 bg-slate-200"></div>
                            </div>

                            <div class="grid gap-5">
                                <div>
                                    <label asp-for="Input.SiteName" class="text-sm font-semibold text-slate-800"></label>
                                    <input asp-for="Input.SiteName" autocomplete="organization" class="@FieldClass("Input.SiteName")" placeholder="Aero CMS" />
                                    <span asp-validation-for="Input.SiteName" class="mt-2 block text-sm font-medium text-rose-600"></span>
                                </div>

                                <div>
                                    <label asp-for="Input.HomepageTitle" class="text-sm font-semibold text-slate-800"></label>
                                    <input asp-for="Input.HomepageTitle" class="@FieldClass("Input.HomepageTitle")" placeholder="Welcome to Aero CMS" />
                                    <span asp-validation-for="Input.HomepageTitle" class="mt-2 block text-sm font-medium text-rose-600"></span>
                                </div>

                                <div>
                                    <label asp-for="Input.BlogName" class="text-sm font-semibold text-slate-800"></label>
                                    <input asp-for="Input.BlogName" class="@FieldClass("Input.BlogName")" placeholder="Field Notes" />
                                    <span asp-validation-for="Input.BlogName" class="mt-2 block text-sm font-medium text-rose-600"></span>
                                </div>
                            </div>
                        </div>

                        <div class="rounded-3xl bg-slate-950 px-5 py-4 text-sm text-slate-200">
                            <p class="font-semibold text-white">What this task does now</p>
                            <p class="mt-2 leading-6 text-slate-300">This form now creates the first admin through Identity managers, ensures the starter roles exist, keeps external return targets out, and preserves entered values on invalid posts. Content seeding and final setup completion still land in later tasks.</p>
                        </div>

                        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                            <p class="text-sm leading-6 text-slate-500">Posting stays Razor Pages-native and antiforgery-compatible.</p>
                            <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-slate-900/20 transition hover:-translate-y-0.5 hover:bg-slate-800 focus:outline-none focus:ring-4 focus:ring-slate-300">Validate setup details</button>
                        </div>
                    </form>
                </section>
            </div>
        </main>
    </div>
</body>
</html>
