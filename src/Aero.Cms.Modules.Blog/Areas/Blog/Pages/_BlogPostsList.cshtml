@using Aero.Cms.Modules.Blog.Areas.Blog.Pages
@model BlogIndexPageModel

@foreach (var post in Model.OtherPosts)
{
    <article class="group relative flex flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:shadow-md hover:border-slate-300">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex-1">
                <h3 class="text-lg font-semibold text-slate-900 group-hover:text-cyan-600 transition-colors">
                    <a href="/@post.Slug" class="block focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2">
                        @post.Title
                    </a>
                </h3>

                @if (post.TagIds.Any())
                {
                    <div class="mt-2 flex flex-wrap items-center gap-1.5">
                        @foreach (var tagId in post.TagIds)
                        {
                            <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-slate-500">
                                @(Model.TagNames.GetValueOrDefault(tagId, $"Tag #{tagId}"))
                            </span>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(post.Excerpt))
                {
                    <p class="mt-3 text-sm text-slate-600 line-clamp-2 leading-relaxed">
                        @post.Excerpt
                    </p>
                }
            </div>

            <div class="mt-2 sm:mt-0 sm:ml-6 sm:flex-shrink-0">
                @if (post.PublishedOn.HasValue)
                {
                    <time datetime="@post.PublishedOn.Value.ToString("yyyy-MM-dd")" class="text-xs font-medium text-slate-400">
                        @post.PublishedOn.Value.ToString("MMM dd, yyyy")
                    </time>
                }
            </div>
        </div>

        <div class="mt-4 flex items-center text-sm font-semibold text-cyan-600">
            <span>Read More</span>
            <svg class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
        </div>
    </article>
}

@if (Model.HasMore)
{
    <div id="load-more-container" class="mt-12 flex justify-center py-4">
        <button hx-get="@Url.Page("BlogIndexPage", "LoadMore", new { p = Model.PageNumber + 1 })"
                hx-target="#load-more-container"
                hx-swap="outerHTML"
                hx-indicator="#loading-spinner"
                class="group relative inline-flex items-center gap-3 rounded-2xl bg-slate-900 px-8 py-4 text-sm font-bold text-white shadow-xl shadow-slate-200 transition-all hover:scale-105 hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2 disabled:opacity-70">
            <span>Show more articles</span>
            <div id="loading-spinner" class="htmx-indicator">
                <svg class="h-4 w-4 animate-spin text-white" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </div>
            <svg class="h-5 w-5 text-slate-400 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
    </div>
}
