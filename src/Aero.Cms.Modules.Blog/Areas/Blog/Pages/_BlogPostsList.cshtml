@model Aero.Cms.Modules.Blog.Areas.Blog.Pages.BlogIndexPageModel

<div class="grid gap-6">
    @foreach (var post in Model.OtherPosts)
    {
        <article class="group relative flex flex-col rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition-all duration-300 hover:shadow-xl hover:border-indigo-100 hover:-translate-y-1">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-3">
                         @if (post.TagIds.Any())
                         {
                             <span class="inline-flex items-center rounded-lg bg-slate-100 px-2 py-1 text-[10px] font-bold uppercase tracking-wider text-slate-500">
                                 @(Model.TagNames.GetValueOrDefault(post.TagIds.First(), "Editorial"))
                             </span>
                         }
                         <span class="text-[10px] font-bold text-slate-300 uppercase tracking-widest">•</span>
                         <time datetime="@(post.PublishedOn?.ToString("yyyy-MM-dd"))" class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                            @(post.PublishedOn?.ToString("MMM dd, yyyy") ?? "Recently")
                        </time>
                    </div>

                    <h3 class="text-xl font-extrabold text-slate-900 group-hover:text-indigo-600 transition-colors leading-tight">
                        <a href="/@post.Slug" class="block focus:outline-none">
                            @post.Title
                        </a>
                    </h3>

                    @if (!string.IsNullOrEmpty(post.Excerpt))
                    {
                        <p class="mt-4 text-base text-slate-500 line-clamp-2 leading-relaxed font-medium">
                            @post.Excerpt
                        </p>
                    }
                </div>

                <div class="h-12 w-12 flex items-center justify-center rounded-2xl bg-slate-50 text-slate-300 transition-all group-hover:bg-indigo-50 group-hover:text-indigo-600 group-hover:rotate-45">
                    <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                </div>
            </div>
        </article>
    }
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-16 flex items-center justify-between border-t border-slate-200 px-4 py-8 sm:px-0">
        <div class="-mt-px flex w-0 flex-1">
            @if (Model.HasPreviousPage)
            {
                <button hx-get="@Url.Page("BlogIndexPage", "PostsPage", new { p = Model.PageNumber - 1 })"
                        hx-target="#posts-container"
                        hx-indicator="#blog-loading-indicator"
                        class="inline-flex items-center border-t-2 border-transparent pr-1 pt-4 text-sm font-bold text-slate-400 hover:border-slate-300 hover:text-slate-900 transition-all">
                    <svg class="mr-3 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a.75.75 0 01-.75.75H4.66l2.1 1.95a.75.75 0 11-1.02 1.1l-3.5-3.25a.75.75 0 010-1.1l3.5-3.25a.75.75 0 111.02 1.1l-2.1 1.95h12.59A.75.75 0 0118 10z" clip-rule="evenodd" />
                    </svg>
                    PREVIOUS
                </button>
            }
        </div>
        
        <div class="hidden md:-mt-px md:flex gap-2">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                if (i == Model.PageNumber)
                {
                    <span class="inline-flex items-center border-t-2 border-indigo-600 px-4 pt-4 text-sm font-black text-indigo-600" aria-current="page">@i</span>
                }
                else
                {
                    <button hx-get="@Url.Page("BlogIndexPage", "PostsPage", new { p = i })"
                            hx-target="#posts-container"
                            hx-indicator="#blog-loading-indicator"
                            class="inline-flex items-center border-t-2 border-transparent px-4 pt-4 text-sm font-bold text-slate-400 hover:border-slate-300 hover:text-slate-900 transition-all">
                        @i
                    </button>
                }
            }
        </div>

        <div class="-mt-px flex w-0 flex-1 justify-end">
            @if (Model.HasNextPage)
            {
                <button hx-get="@Url.Page("BlogIndexPage", "PostsPage", new { p = Model.PageNumber + 1 })"
                        hx-target="#posts-container"
                        hx-indicator="#blog-loading-indicator"
                        class="inline-flex items-center border-t-2 border-transparent pl-1 pt-4 text-sm font-bold text-slate-400 hover:border-slate-300 hover:text-slate-900 transition-all">
                    NEXT
                    <svg class="ml-3 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd" />
                    </svg>
                </button>
            }
        </div>
    </nav>
}

<div id="blog-loading-indicator" class="htmx-indicator fixed inset-0 z-[60] flex items-center justify-center bg-slate-900/10 backdrop-blur-[2px]">
    <div class="flex flex-col items-center gap-4 p-8 rounded-3xl bg-white shadow-2xl">
        <div class="h-12 w-12 animate-spin rounded-full border-4 border-indigo-600 border-t-transparent"></div>
        <span class="text-xs font-bold text-indigo-600 uppercase tracking-widest">Loading Page...</span>
    </div>
</div>
