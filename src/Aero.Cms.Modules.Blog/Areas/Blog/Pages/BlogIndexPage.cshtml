@page "/blog"

@model BlogIndexPageModel

@{
    ViewBag.Title = "Blog";
}

<div class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-100">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-12 text-center">
            <h1 class="font-display text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
                Blog
            </h1>
            <p class="mt-4 text-lg text-slate-600">
                Latest thoughts, stories, and ideas
            </p>
        </div>

        <!-- Blog Posts Grid -->
        @if (Model.Posts.Any())
        {
            <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
                @foreach (var post in Model.Posts)
                {
                    <article class="group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
                        <!-- Card Content -->
                        <div class="flex flex-1 flex-col p-6">
                            <!-- Title Link -->
                            <h2 class="mb-3 text-xl font-semibold leading-tight text-slate-900">
                                <a href="/blog/@post.Slug" class="hover:text-cyan-600 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2">
                                    <span class="absolute inset-0" aria-hidden="true"></span>
                                    @post.Title
                                </a>
                            </h2>

                            <!-- Excerpt -->
                            @if (!string.IsNullOrEmpty(post.Excerpt))
                            {
                                <p class="mb-4 flex-1 text-sm leading-relaxed text-slate-600 line-clamp-3">
                                    @post.Excerpt
                                </p>
                            }
                            else
                            {
                                <p class="mb-4 flex-1 text-sm italic text-slate-400">
                                    No excerpt available
                                </p>
                            }

                            <!-- Meta Info -->
                            <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-4 text-sm">
                                <!-- Published Date -->
                                @if (post.PublishedOn.HasValue)
                                {
                                    <time datetime="@post.PublishedOn.Value.ToString("yyyy-MM-dd")" class="text-slate-500">
                                        @post.PublishedOn.Value.ToString("MMM dd, yyyy")
                                    </time>
                                }
                                else
                                {
                                    <span class="text-slate-400">Draft</span>
                                }

                                <!-- Author -->
                                @if (post.AuthorId.HasValue)
                                {
                                    <span class="flex items-center gap-1.5 text-slate-600">
                                        <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                        </svg>
                                        <span>Author #@post.AuthorId.Value</span>
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Read More Indicator -->
                        <div class="flex items-center justify-between border-t border-slate-100 bg-slate-50/50 px-6 py-3">
                            <span class="text-sm font-medium text-cyan-600 group-hover:text-cyan-700">
                                Read more
                            </span>
                            <svg class="h-5 w-5 text-cyan-600 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="flex flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-300 bg-white/50 py-16">
                <svg class="h-16 w-16 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-slate-900">No posts yet</h3>
                <p class="mt-2 text-center text-slate-500">Check back soon for new content!</p>
            </div>
        }
    </div>
</div>
