<div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:shadow-md transition-shadow group">
    <div class="flex items-center justify-between mb-3">
        <div class="p-2 rounded-lg @Color.Replace("bg-", "text-").Replace("-500", "-600") @Color.Replace("-500", "-50")">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@Icon" />
            </svg>
        </div>
        @if (!string.IsNullOrEmpty(Change))
        {
            <span class="text-[10px] font-bold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full ring-1 ring-emerald-100">@Change</span>
        }
    </div>
    <div class="space-y-1">
        <h4 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">@Label</h4>
        <div class="text-2xl font-bold text-gray-900 tracking-tight">@Value</div>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string? Change { get; set; }
    [Parameter] public string Color { get; set; } = "bg-indigo-500";
    [Parameter] public string Icon { get; set; } = "";
}
