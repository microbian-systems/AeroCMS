@page "/manager/tags"

<PageTitle>Tags - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900 leading-tight">Content Discovery: Tags</h1>
    </div>

    <div class="bg-white p-12 border border-gray-200 rounded-2xl shadow-sm text-center">
        <div class="flex flex-wrap justify-center gap-3">
            <span class="px-6 py-2 bg-indigo-50 text-indigo-700 rounded-full font-bold text-sm shadow-sm hover:shadow-md transition-all cursor-pointer border border-indigo-100 italic transition-all duration-300">#NETCore</span>
            <span class="px-6 py-2 bg-rose-50 text-rose-700 rounded-full font-bold text-sm shadow-sm hover:shadow-md transition-all cursor-pointer border border-rose-100 italic">#SAAS</span>
            <span class="px-6 py-2 bg-emerald-50 text-emerald-700 rounded-full font-bold text-sm shadow-sm hover:shadow-md transition-all cursor-pointer border border-emerald-100 italic">#Architecture</span>
            <span class="px-6 py-2 bg-amber-50 text-amber-700 rounded-full font-bold text-sm shadow-sm hover:shadow-md transition-all cursor-pointer border border-amber-100 italic">#Telemetry</span>
            <span class="px-6 py-2 bg-blue-50 text-blue-700 rounded-full font-bold text-sm shadow-sm hover:shadow-md transition-all cursor-pointer border border-blue-100 italic">#CloudStrategy</span>
        </div>
        <div class="mt-8">
            <button class="px-6 py-2 bg-indigo-600 text-white rounded-lg font-bold shadow-sm hover:bg-indigo-700 transition-all font-semibold italic text-sm">Harvest New Semantic Tags</button>
        </div>
    </div>
</div>
