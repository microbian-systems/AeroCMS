@page "/manager/themes"

<PageTitle>Themes - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900 italic tracking-tight uppercase leading-tight">Visual Experience Themes</h1>
        <button class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-semibold shadow-sm hover:bg-indigo-700 transition-all flex items-center space-x-2">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
            <span>Stage Theme Bundle</span>
        </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-indigo-600 p-8 rounded-2xl text-white shadow-xl shadow-indigo-100 flex flex-col justify-between h-56 border-4 border-indigo-400">
             <div>
                <h4 class="font-bold text-lg italic tracking-tight uppercase leading-tight">Aero Enterprise Dark</h4>
                <p class="text-[10px] text-indigo-100 uppercase tracking-widest mt-1 italic font-mono uppercase">system active theme</p>
                <div class="text-xs text-indigo-100 mt-4 leading-relaxed font-semibold italic">Optimized for high-performance content orchestration in dark mode environments.</div>
            </div>
             <div class="flex items-center justify-between">
                <span class="text-[10px] font-bold uppercase tracking-widest text-indigo-100">Version 1.2.4</span>
                <span class="px-3 py-1 bg-white text-indigo-600 rounded-lg text-[10px] font-bold uppercase tracking-widest">Selected</span>
             </div>
        </div>

        <div class="bg-white p-8 rounded-2xl border border-gray-200 shadow-sm hover:border-indigo-400 h-56 flex flex-col justify-between transition-all group cursor-pointer hover:shadow-xl hover:-translate-y-1">
             <div>
                <h4 class="font-bold text-lg italic tracking-tight uppercase leading-tight group-hover:text-indigo-600 transition-colors">Aero Glass Minimal</h4>
                <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-1 italic font-mono uppercase">available extension</p>
                <div class="text-xs text-gray-500 mt-4 leading-relaxed italic">Transparent glassmorphism layout for ultra-modern landing page reach.</div>
            </div>
             <div class="flex items-center justify-between">
                 <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Version 0.9.3</span>
                 <button class="text-[10px] font-bold uppercase tracking-widest text-indigo-600 hover:underline">Apply Theme</button>
             </div>
        </div>
    </div>
</div>
