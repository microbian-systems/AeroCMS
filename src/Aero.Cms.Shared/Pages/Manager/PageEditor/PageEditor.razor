                </button>
                @if (CategoryMedia)
                {
                    <div class="pe-category-items">
                        <SidebarBlockItem Label="Image" @ondragstart='e => DragStart(e, "image")' OnClick='() => AddBlock("image")'>
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                            <circle cx="8.5" cy="8.5" r="1.5"/>
                            <polyline points="21 15 16 10 5 21"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Video" @ondragstart='e => DragStart(e, "video")' OnClick='() => AddBlock("video")'>
                            <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/>
                            <line x1="7" y1="2" x2="7" y2="22"/>
                            <line x1="17" y1="2" x2="17" y2="22"/>
                            <line x1="2" y1="12" x2="22" y2="12"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Gallery" @ondragstart='e => DragStart(e, "gallery")' OnClick='() => AddBlock("gallery")'>
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                            <circle cx="8.5" cy="8.5" r="1.5"/>
                            <polyline points="21 15 16 10 5 21"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Audio" @ondragstart='e => DragStart(e, "audio")' OnClick='() => AddBlock("audio")'>
                            <path d="M9 18V5l12-2v13"/>
                            <circle cx="6" cy="18" r="3"/>
                            <circle cx="18" cy="16" r="3"/>
