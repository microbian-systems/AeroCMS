@page "/manager/page/editor"
@page "/manager/page/editor/{id:long}"
@attribute [Authorize]

@* @layout _PageEditorLayout *@
@using Aero.Cms.Abstractions.Enums
@using Aero.Cms.Core.Blocks
@using Aero.Cms.Core.Blocks.Common
@using Aero.Cms.Shared.Blocks.Rendering
@using Aero.Cms.Shared.Layout
@using Microsoft.AspNetCore.Components.Sections
@using Aero.Cms.Core

@* ── Editor area (Content) ───────────────────────────── *@
@* Note: .pe-editor-area is now provided by ManagerShellLayout *@
@* We just need to handle the internal page header and block container *@

<div class="pe-tabs" style="background: var(--pe-bg-secondary); border-bottom: 1px solid var(--pe-border); display: flex; padding: 8px 8px 0; gap: 4px;">
    <button class="pe-tab-btn @(ActiveTab == "editor" ? "active" : "")" 
            @onclick='() => ActiveTab = "editor"'>
        Content Editor
    </button>
    <button class="pe-tab-btn @(ActiveTab == "metadata" ? "active" : "")" 
            @onclick='() => ActiveTab = "metadata"'>
        Metadata
    </button>
</div>

@if (ActiveTab == "editor")
{
@* Page header (edit mode) *@
@if (!PreviewMode)
{
    <div class="pe-page-header">
        <input class="pe-page-title-input" type="text" placeholder="Page Title"
               value="@PageTitle" @oninput="e => PageTitle = e.Value?.ToString() ?? string.Empty"/>
        <div class="pe-page-meta">
            <div class="pe-meta-left">
                <span class="pe-meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    Last saved: <strong>@LastSaved</strong>
                </span>
                <span class="pe-meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    @Author
                </span>
            </div>
            <div class="pe-meta-right">
                <button class="pe-btn pe-btn-ghost pe-btn-sm" @onclick="TogglePreview">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                    Preview
                </button>
                <button class="pe-btn @(IsSaving ? "pe-btn-secondary" : "pe-btn-primary") pe-btn-sm" @onclick="SavePage" disabled="@IsSaving">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                        <polyline points="17 21 17 13 7 13 7 21"/>
                        <polyline points="7 3 7 8 15 8"/>
                    </svg>
                    @(IsSaving ? "Saving..." : "Save")
                </button>
                <button class="pe-btn pe-btn-success pe-btn-sm" @onclick="PublishPage">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Publish
                </button>
            </div>
        </div>
    </div>
}

@* Preview device toolbar *@
@if (PreviewMode)
{
    <div class="pe-preview-header">
        <div class="pe-preview-devices">
            <button class="pe-device-btn @(PreviewDevice == "desktop" ? "active" : "")" title="Desktop" @onclick='() => PreviewDevice = "desktop"'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
            </button>
            <button class="pe-device-btn @(PreviewDevice == "tablet" ? "active" : "")" title="Tablet" @onclick='() => PreviewDevice = "tablet"'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
                    <line x1="12" y1="18" x2="12.01" y2="18"/>
                </svg>
            </button>
            <button class="pe-device-btn @(PreviewDevice == "mobile" ? "active" : "")" title="Mobile" @onclick='() => PreviewDevice = "mobile"'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                    <line x1="12" y1="18" x2="12.01" y2="18"/>
                </svg>
            </button>
        </div>
        <button class="pe-btn pe-btn-ghost" @onclick="TogglePreview">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
            Close Preview
        </button>
    </div>
}

@* Blocks canvas *@
<div class="pe-blocks-container @(PreviewMode ? "preview-" + PreviewDevice : "")"
     @ondragover:preventDefault
     @ondrop="OnDropCanvas">

    @* Empty state *@
    @if (Blocks.Count == 0 && !PreviewMode)
    {
        <div class="pe-empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
                 style="cursor: pointer" @onclick="() => RightSidebarCollapsed = false">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <line x1="12" y1="8" x2="12" y2="16"/>
                <line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            <h3>Start building your page</h3>
            <p>Drag blocks from the sidebar or click to add them here</p>
        </div>
    }

    @* Block list *@
    @for (var i = 0; i < Blocks.Count; i++)
    {
        var block = Blocks[i];
        var index = i; // capture for lambda
        var isSelected = SelectedBlockId == block.EditorId;

        <div class="pe-block-wrapper @(isSelected ? "selected" : "") @(DraggedBlockId == block.EditorId ? "dragging" : "") @(DragOverIndex == index ? "drag-over" : "")"
             @onclick="() => SelectBlock(block.EditorId)"
             draggable="true"
             @ondragstart="e => DragStartBlock(e, block.EditorId, index)"
             @ondragover="e => DragOverBlock(e, index)"
             @ondragover:preventDefault
             @ondrop="e => DropBlock(e, index)"
             @ondrop:stopPropagation>

            @* Toolbar *@
            @if (isSelected && !PreviewMode)
            {
                <div class="pe-block-toolbar">
                    <button class="pe-toolbar-btn" title="Move up"
                            disabled="@(index == 0)"
                            @onclick:stopPropagation="true"
                            @onclick="() => MoveBlockUp(index)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="18 15 12 9 6 15"/>
                        </svg>
                    </button>
                    <button class="pe-toolbar-btn" title="Move down"
                            disabled="@(index == Blocks.Count - 1)"
                            @onclick:stopPropagation="true"
                            @onclick="() => MoveBlockDown(index)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </button>
                    <button class="pe-toolbar-btn" title="Duplicate"
                            @onclick:stopPropagation="true"
                            @onclick="() => DuplicateBlock(index)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                    </button>
                    <button class="pe-toolbar-btn delete" title="Delete"
                            @onclick:stopPropagation="true"
                            @onclick="() => DeleteBlock(index)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"/>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                    </button>
                </div>
            }

            <div class="pe-block-content">
                @RenderBlock(block, isSelected)
            </div>
        </div>
    }
</div>
}
else if (ActiveTab == "metadata")
{
    <div class="p-6 rounded-lg shadow-sm m-4 space-y-6 max-w-4xl" style="background: var(--pe-bg-secondary); color: var(--pe-text-primary);">
        <h2 class="text-xl font-semibold mb-4" style="color: var(--pe-text-primary);">Page Metadata</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--pe-text-secondary);">Page Title</label>
                    <input type="text" class="w-full rounded-md shadow-sm sm:text-sm"
                           style="background: var(--pe-bg-primary); color: var(--pe-text-primary); border: 1px solid var(--pe-border);"
                           @bind="PageTitle" placeholder="e.g. About Us" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--pe-text-secondary);">URL Slug</label>
                    <input type="text" class="w-full rounded-md shadow-sm sm:text-sm font-mono"
                           style="background: var(--pe-bg-primary); color: var(--pe-primary); border: 1px solid var(--pe-border);"
                           @bind="PageSlug" placeholder="e.g. about-us" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--pe-text-secondary);">Summary / Excerpt</label>
                    <textarea rows="3" class="w-full rounded-md shadow-sm sm:text-sm"
                              style="background: var(--pe-bg-primary); color: var(--pe-text-primary); border: 1px solid var(--pe-border);"
                              @bind="Summary" placeholder="Brief description..."></textarea>
                </div>
                <div class="flex items-center gap-2 pt-2">
                    <input type="checkbox" id="metaChkNav" @bind="ShowInNavMenu" class="h-4 w-4 rounded" 
                           style="background: var(--pe-bg-primary); border-color: var(--pe-border); color: var(--pe-primary);" />
                    <label for="metaChkNav" class="text-sm font-medium" style="color: var(--pe-text-secondary);">Show in Navigation Menu</label>
                </div>
            </div>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--pe-text-secondary);">SEO Meta Title</label>
                    <input type="text" class="w-full rounded-md shadow-sm sm:text-sm"
                           style="background: var(--pe-bg-primary); color: var(--pe-text-primary); border: 1px solid var(--pe-border);"
                           @bind="SeoTitle" placeholder="Custom Browser Title" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1" style="color: var(--pe-text-secondary);">SEO Meta Description</label>
                    <textarea rows="3" class="w-full rounded-md shadow-sm sm:text-sm"
                              style="background: var(--pe-bg-primary); color: var(--pe-text-primary); border: 1px solid var(--pe-border);"
                              @bind="SeoDescription" placeholder="Description for search engines..."></textarea>
                </div>
            </div>
        </div>

        <div class="mt-8 pt-6 border-t" style="border-top-color: var(--pe-border);">
            <h3 class="text-lg font-medium mb-4" style="color: var(--pe-text-primary);">Publishing &amp; History</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 rounded-md border" 
                 style="background: var(--pe-bg-primary); border-color: var(--pe-border);">
                <div>
                    <span class="block text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--pe-text-muted);">Status</span>
                    @if (PublicationState == ContentPublicationState.Published)
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" 
                              style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">
                            Published
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" 
                              style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">
                            Draft
                        </span>
                    }
                </div>
                <div>
                    <span class="block text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--pe-text-muted);">Date Created</span>
                    <span class="text-sm font-medium" style="color: var(--pe-text-primary);">@(LoadedPage?.CreatedAt.ToShortDateString() ?? "-")</span>
                </div>
                <div>
                    <span class="block text-xs font-semibold uppercase tracking-wider mb-1" style="color: var(--pe-text-muted);">Date Modified</span>
                    <span class="text-sm font-medium" style="color: var(--pe-text-primary);">@(LoadedPage?.UpdatedAt.ToShortDateString() ?? "-")</span>
                </div>
            </div>
        </div>
    </div>
}

@* Right sidebar content *@
<SectionContent SectionName="RightSidebar">
    <AeroSidebar Title="Blocks" Side="SidebarSide.Right" @bind-IsCollapsed="RightSidebarCollapsed">
        <div class="pe-blocks-sidebar">
            @* Content category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("content")'>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                    @if (!RightSidebarCollapsed)
                    {
                        @:Content
                        <svg class="pe-chevron @(CategoryContent ? "rotated" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    }
                </button>
                @if (CategoryContent)
                {
                    <div class="pe-category-items">
                        <SidebarBlockItem Label="Hero" @ondragstart='e => DragStart(e, "hero")' OnClick='() => AddBlock("hero")'>
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <line x1="3" y1="9" x2="21" y2="9"/>
                            <line x1="9" y1="21" x2="9" y2="9"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Text" @ondragstart='e => DragStart(e, "text")' OnClick='() => AddBlock("text")'>
                            <polyline points="4 7 4 4 20 4 20 7"/>
                            <line x1="9" y1="20" x2="15" y2="20"/>
                            <line x1="12" y1="4" x2="12" y2="20"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Columns" @ondragstart='e => DragStart(e, "columns")' OnClick='() => AddBlock("columns")'>
                            <rect x="3" y="3" width="7" height="18"/>
                            <rect x="14" y="3" width="7" height="18"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Auth" 
                                          @ondragstart='e => DragStart(e, "aero_auth")'
                                          OnClick='() => AddBlock("aero_auth")'>
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M13.8 12H3"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Rich Text" @ondragstart='e => DragStart(e, "content")' OnClick='() => AddBlock("content")'>
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <line x1="3" y1="9" x2="21" y2="9"/>
                            <line x1="9" y1="21" x2="9" y2="9"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Markdown" @ondragstart='e => DragStart(e, "markdown")' OnClick='() => AddBlock("markdown")'>
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Quote" @ondragstart='e => DragStart(e, "quote")' OnClick='() => AddBlock("quote")'>
                            <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Separator" @ondragstart='e => DragStart(e, "separator")' OnClick='() => AddBlock("separator")'>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </SidebarBlockItem>
                    </div>
                }
            </div>
 
            @* Aero Meraki category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("aero")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                    @if (!RightSidebarCollapsed)
                    {
                        @:Aero UX
                        <svg class="pe-chevron @(CategoryAero ? "rotated" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    }
                </button>
                @if (CategoryAero)
                {
                    <div class="pe-category-items">
