                        <SidebarBlockItem Label="Table" 
                                          @ondragstart='e => DragStart(e, "aero_table")'
                                          OnClick='() => AddBlock("aero_table")'>
                            
                                <path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/>
                            
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Auth" 
                                          @ondragstart='e => DragStart(e, "aero_auth")'
                                          OnClick='() => AddBlock("aero_auth")'>
                            
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M13.8 12H3"/>
                            
                        </SidebarBlockItem>
                    </div>
                }
            </div>

            @* Media category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("media")'>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
