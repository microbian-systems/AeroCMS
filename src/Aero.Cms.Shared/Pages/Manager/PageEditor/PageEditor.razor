            </div>

            @* References category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("references")'>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                    </svg>
                    @if (!RightSidebarCollapsed)
                    {
                        @:References
                        <svg class="pe-chevron @(CategoryReferences ? "rotated" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    }
                </button>
                @if (CategoryReferences)
                {
                    <div class="pe-category-items">
                        <SidebarBlockItem Label="Pages" @ondragstart='e => DragStart(e, "pages")' OnClick='() => AddBlock("pages")'>
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Posts" @ondragstart='e => DragStart(e, "posts")' OnClick='() => AddBlock("posts")'>
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                            <polyline points="10 9 9 9 8 9"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Categories" @ondragstart='e => DragStart(e, "categories")' OnClick='() => AddBlock("categories")'>
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Tags" @ondragstart='e => DragStart(e, "tags")' OnClick='() => AddBlock("tags")'>
                            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                            <line x1="7" y1="7" x2="7.01" y2="7"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Authors" @ondragstart='e => DragStart(e, "authors")' OnClick='() => AddBlock("authors")'>
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </SidebarBlockItem>
                    </div>
                }
            </div>


        </div>
    </AeroSidebar>
</SectionContent>


@* ── Media selector modal ────────────────────────────────── *@
<MediaSelectorModal
    Show="MediaModalOpen"
    MultiSelect="IsGalleryMode"
    Library="MediaLibrary"
    OnClose="() => MediaModalOpen = false"
    OnConfirm="OnConfirmMediaSelection"
    OnUpload="e => HandleFileSelect(e)"/>

@* ── Toast notifications ─────────────────────────────────── *@
<div class="pe-toast-container">
    @foreach (var toast in Toasts)
    {
        <div class="pe-toast @toast.Type" @onclick="() => RemoveToast(toast.Id)">
            @if (toast.Type == "success")
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            }
            else if (toast.Type == "error")
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            }
            else
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="16" x2="12" y2="12"/>
                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
            }
            <span>@toast.Message</span>
        </div>
    }
</div>
@* ... (Toasts and Modals retained) ... *@

@* ── Inline render helpers ───────────────────────────────── *@

@code {

    RenderFragment RenderBlock(EditorBlock block, bool isSelected) => block.Type switch
    {
        "hero" => RenderHeroBlock(block, isSelected),
        "aero_hero"         => RenderAeroHeroBlock(block, isSelected),
        "aero_features"     => RenderAeroFeaturesBlock(block, isSelected),
        "aero_cta"          => RenderAeroCtaBlock(block, isSelected),
        "aero_blog"         => RenderAeroBlogBlock(block, isSelected),
        "aero_pricing"      => RenderAeroPricingBlock(block, isSelected),
        "aero_teams"        => RenderAeroTeamsBlock(block, isSelected),
        "aero_testimonials" => RenderAeroTestimonialsBlock(block, isSelected),
        "aero_faq"          => RenderAeroFaqBlock(block, isSelected),
        "aero_portfolio"    => RenderAeroPortfolioBlock(block, isSelected),
        "aero_contact"      => RenderAeroContactBlock(block, isSelected),
        "aero_table"        => RenderAeroTableBlock(block, isSelected),
        "aero_auth"         => RenderAeroAuthBlock(block, isSelected),
        "text" => RenderTextBlock(block),
        "content" => RenderContentBlock(block),
        "markdown" => RenderMarkdownBlock(block),
        "quote" => RenderQuoteBlock(block),
        "separator" => RenderSeparatorBlock(),
        "columns" => RenderColumnsBlock(block, isSelected),
        "image" => RenderImageBlock(block),
        "video" => RenderVideoBlock(block),
        "gallery" => RenderGalleryBlock(block),
        "audio" => RenderAudioBlock(block),
        "raw_html" => RenderHtmlBlock(block),
        _ => RenderReferenceBlock(block),
    };

    // ── Hero ───────────────────────────────────────────────────
    RenderFragment RenderHeroBlock(EditorBlock b, bool sel) => __builder =>
    {
        <div class="pe-hero-block"
             style="@(string.IsNullOrEmpty(b.BackgroundImage) ? "" : $"background-image:url({b.BackgroundImage})")">
            @if (!string.IsNullOrEmpty(b.BackgroundImage))
            {
                <div class="pe-hero-overlay"></div>
            }
            <div class="pe-hero-content">
                <input class="pe-hero-title" type="text" placeholder="Main Headline"
                       value="@b.MainText" @oninput="e => b.MainText = e.Value?.ToString() ?? string.Empty"
                       @onfocus="() => SelectBlock(b.EditorId)"/>
                <input class="pe-hero-subtitle" type="text" placeholder="Sub headline or description"
                       value="@b.SubText" @oninput="e => b.SubText = e.Value?.ToString() ?? string.Empty"
                       @onfocus="() => SelectBlock(b.EditorId)"/>
                <div class="pe-hero-cta-row">
                    <input class="pe-hero-cta-text" type="text" placeholder="Button text"
                           value="@b.CtaText" @oninput="e => b.CtaText = e.Value?.ToString() ?? string.Empty"
                           @onfocus="() => SelectBlock(b.EditorId)"/>
                    <input class="pe-hero-cta-url" type="text" placeholder="Button URL"
                           value="@b.CtaUrl" @oninput="e => b.CtaUrl = e.Value?.ToString() ?? string.Empty"
                           @onfocus="() => SelectBlock(b.EditorId)"/>
                </div>
                <div class="pe-hero-bg-controls">
                    @if (string.IsNullOrEmpty(b.BackgroundImage))
                    {
                        <button class="pe-btn pe-btn-secondary pe-btn-sm"
                                @onclick='() => OpenMediaSelector(b, false, "background")'>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                <polyline points="21 15 16 10 5 21"/>
                            </svg>
                            Add Background Image
                        </button>
                    }
                    else
                    {
                        <button class="pe-btn pe-btn-ghost pe-btn-sm"
                                @onclick="() => b.BackgroundImage = string.Empty">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18"/>
                                <line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                            Remove Background
                        </button>
                    }
                </div>
            </div>
        </div>
    };
 
    // ── Aero Hero ──────────────────────────────────────────────
    RenderFragment RenderAeroHeroBlock(EditorBlock b, bool sel) => __builder =>
    {
        var model = new AeroHeroBlock
        {
            Title = b.MainText,
            Description = b.SubText,
            Layout = Enum.TryParse<AeroHeroLayout>(b.AeroLayout, true, out var layout) ? layout : AeroHeroLayout.SideImage,
            Buttons = new List<AeroButton>
            {
                new() { Text = b.CtaText, Url = b.CtaUrl, Style = Enum.TryParse<AeroButtonStyle>(b.Button1Style, true, out var s1) ? s1 : AeroButtonStyle.Primary },
                new() { Text = b.CtaText2, Url = b.CtaUrl2, Style = Enum.TryParse<AeroButtonStyle>(b.Button2Style, true, out var s2) ? s2 : AeroButtonStyle.Secondary }
            },
            BackgroundImage = b.BackgroundImage
        };

        <div class="pe-aero-hero-block @(sel ? "pe-selected" : "")" @onclick:stopPropagation>
             <AeroHeroRenderer Block="model" />
             
             @if (sel && !PreviewMode)
             {
                 <div class="pe-aero-controls">
                     <div class="pe-aero-controls-grid">
                         <div class="pe-control-group">
                             <label>Headline</label>
                             <input type="text" @bind="b.MainText" @bind:event="oninput" placeholder="Main Headline" />
                         </div>
                         <div class="pe-control-group">
                             <label>Description</label>
                             <textarea @bind="b.SubText" @bind:event="oninput" placeholder="Description text..." rows="2"></textarea>
                         </div>
                         <div class="pe-control-group">
                             <label>Layout</label>
                             <select @bind="b.AeroLayout">
                                 <option value="SideImage">Side Image (Left)</option>
                                 <option value="CenterContent">Center Content</option>
                                 <option value="BackgroundImage">Background Image</option>
                             </select>
                         </div>
                          <div class="pe-control-group">
                             <label>Background Image</label>
                             <div class="pe-input-with-btn">
                                 <input type="text" @bind="b.BackgroundImage" placeholder="Image URL..." />
                                 <button class="pe-btn pe-btn-sm" @onclick='() => OpenMediaSelector(b, false, "background")'>
                                     <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                                     </svg>
                                 </button>
                             </div>
                         </div>
                         <div class="pe-control-row">
                             <div class="pe-control-group">
                                 <label>Primary Button</label>
                                 <input type="text" @bind="b.CtaText" placeholder="Label" />
                                 <input type="text" @bind="b.CtaUrl" placeholder="URL (#)" />
                                 <select @bind="b.Button1Style">
                                     <option value="Primary">Primary</option>
                                     <option value="Secondary">Secondary</option>
                                     <option value="Outline">Outline</option>
                                 </select>
                             </div>
                             <div class="pe-control-group">
                                 <label>Secondary Button</label>
                                 <input type="text" @bind="b.CtaText2" placeholder="Label" />
                                 <input type="text" @bind="b.CtaUrl2" placeholder="URL (#)" />
                                 <select @bind="b.Button2Style">
                                     <option value="Primary">Primary</option>
                                     <option value="Secondary">Secondary</option>
                                     <option value="Outline">Outline</option>
                                 </select>
                             </div>
                         </div>
                     </div>
                 </div>
             }
        </div>
    };

    // ── Aero Features ──────────────────────────────────────────
    RenderFragment RenderAeroFeaturesBlock(EditorBlock b, bool sel) => __builder =>
    {
        var aeroFeatures = new AeroFeaturesBlock
        {
            Title = b.MainText,
            SubTitle = b.SubText,
            Layout = Enum.TryParse<AeroFeaturesLayout>(b.AeroLayout, true, out var layout) ? layout : AeroFeaturesLayout.Simple,
            Items = b.FeatureItems
        };

        <div class="pe-aero-hero-block @(sel ? "pe-selected" : "")" @onclick="() => SelectBlock(b.EditorId)" @onclick:stopPropagation>
            <div class="pe-aero-badge">Aero Features</div>
                
            <AeroFeaturesRenderer Block="aeroFeatures" />

            @if (sel && !PreviewMode)
            {
                <div class="pe-aero-controls">
                    <div class="pe-aero-controls-grid">
                        <div class="pe-control-row">
                            <div class="pe-control-group">
                                <label>Section Title</label>
                                <input @bind="b.MainText" @bind:event="oninput" placeholder="Enter title..." />
                            </div>
                            <div class="pe-control-group">
                                <label>Layout</label>
                                <select @bind="b.AeroLayout">
                                    <option value="Simple">Simple</option>
                                    <option value="Centered">Centered</option>
                                    <option value="Cards">Cards</option>
                                    <option value="GridList">Grid List</option>
                                    <option value="Media">Media Grid</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="pe-control-group">
                            <label>Description</label>
                            <textarea @bind="b.SubText" @bind:event="oninput" rows="2" placeholder="Enter description..."></textarea>
                        </div>

                        <div class="pe-features-editor">
                            <label class="pe-label-mini">Feature Items (@b.FeatureItems.Count)</label>
                            <div class="pe-features-list">
                                @foreach (var item in b.FeatureItems)
                                {
                                    <div class="pe-feature-item-row">
                                        <input @bind="item.Title" placeholder="Feature Title" class="pe-mini-input" />
                                        <button class="pe-btn-icon-red" @onclick="() => b.FeatureItems.Remove(item)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                }
                                <button class="pe-btn-add-mini" @onclick='() => b.FeatureItems.Add(new AeroFeatureItem { Title = "New Feature", Description = "Description..." })'>
                                    <i class="fa-solid fa-plus mr-1"></i> Add Feature
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    };

    // ── Aero CTA ────────────────────────────────────────────────
    RenderFragment RenderAeroCtaBlock(EditorBlock b, bool sel) => __builder =>
    {
        var aeroCta = new AeroCtaBlock
        {
            Title = b.MainText,
            Description = b.Description,
            CtaText = b.CtaText,
            CtaUrl = b.CtaUrl,
            Layout = Enum.TryParse<AeroCtaLayout>(b.AeroLayout, true, out var layout) ? layout : AeroCtaLayout.Card
        };

        <div class="pe-aero-hero-block @(sel ? "pe-selected" : "")" @onclick="() => SelectBlock(b.EditorId)" @onclick:stopPropagation>
            <div class="pe-aero-badge">Aero CTA</div>
            <AeroCtaRenderer Block="aeroCta" />

            @if (sel && !PreviewMode)
            {
                <div class="pe-aero-controls">
                    <div class="pe-aero-controls-grid">
                        <div class="pe-control-group">
                            <label>Headline</label>
                            <input @bind="b.MainText" @bind:event="oninput" />
                        </div>
                        <div class="pe-control-group">
                            <label>Description</label>
                            <textarea @bind="b.Description" @bind:event="oninput" rows="2"></textarea>
                        </div>
                        <div class="pe-control-row">
                            <div class="pe-control-group">
                                <label>Button Text</label>
                                <input @bind="b.CtaText" @bind:event="oninput" />
                            </div>
                            <div class="pe-control-group">
                                <label>Button URL</label>
                                <input @bind="b.CtaUrl" @bind:event="oninput" />
                            </div>
                        </div>
                        <div class="pe-control-group">
                            <label>Layout</label>
                            <select @bind="b.AeroLayout">
                                <option value="Simple">Simple</option>
                                <option value="Card">Card</option>
                                <option value="Split">Split</option>
                            </select>
                        </div>
                    </div>
                </div>
            }
        </div>
    };

    // ── Aero Blog ───────────────────────────────────────────────
    RenderFragment RenderAeroBlogBlock(EditorBlock b, bool sel) => __builder =>
    {
        var aeroBlog = new AeroBlogBlock
        {
            Title = b.SectionTitle,
            Description = b.Description,
            Posts = b.BlogPosts
        };

        <div class="pe-aero-hero-block @(sel ? "pe-selected" : "")" @onclick="() => SelectBlock(b.EditorId)" @onclick:stopPropagation>
            <div class="pe-aero-badge">Aero Blog</div>
            <AeroBlogRenderer Block="aeroBlog" />

            @if (sel && !PreviewMode)
            {
                <div class="pe-aero-controls">
                    <div class="pe-aero-controls-grid">
                        <div class="pe-control-group">
                            <label>Section Title</label>
                            <input @bind="b.SectionTitle" @bind:event="oninput" />
                        </div>
                        <div class="pe-control-group">
                            <label>Description</label>
                            <textarea @bind="b.Description" @bind:event="oninput" rows="2"></textarea>
                        </div>
                        <div class="pe-list-editor">
                            <label class="pe-label-mini">Posts (@b.BlogPosts.Count)</label>
                            @foreach (var post in b.BlogPosts)
                            {
                                <div class="pe-list-item-row">
                                    <input @bind="post.Title" placeholder="Post Title" class="pe-mini-input" />
                                    <button class="pe-btn-icon-red" @onclick="() => b.BlogPosts.Remove(post)">
                                        <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    </button>
                                </div>
                            }
                            <button class="pe-btn-add-mini" @onclick='() => b.BlogPosts.Add(new AeroBlogItem { Title = "New Post", Description = "Excerpt...", PublishedAt = "Oct 2025" })'>
                                Add Post
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    };

    // ── Aero Pricing ────────────────────────────────────────────
    RenderFragment RenderAeroPricingBlock(EditorBlock b, bool sel) => __builder =>
    {
        var aeroPricing = new AeroPricingBlock
        {
            Title = b.PageTitle,
            Description = b.PageDescription,
            Plans = b.PricingPlans
        };

        <div class="pe-aero-hero-block @(sel ? "pe-selected" : "")" @onclick="() => SelectBlock(b.EditorId)" @onclick:stopPropagation>
            <div class="pe-aero-badge">Aero Pricing</div>
            <AeroPricingRenderer Block="aeroPricing" />

            @if (sel && !PreviewMode)
            {
                <div class="pe-aero-controls">
                    <div class="pe-aero-controls-grid">
                         <div class="pe-control-group">
                            <label>Page Title</label>
                            <input @bind="b.PageTitle" @bind:event="oninput" />
                        </div>
                        <div class="pe-control-group">
                            <label>Description</label>
                            <textarea @bind="b.PageDescription" @bind:event="oninput" rows="2"></textarea>
                        </div>
                        <div class="pe-list-editor">
                            <label class="pe-label-mini">Plans (@b.PricingPlans.Count)</label>
                            @foreach (var plan in b.PricingPlans)
                            {
                                <div class="pe-list-item-row">
                                    <input @bind="plan.Name" class="pe-mini-input" />
                                    <input @bind="plan.Price" style="width: 60px" class="pe-mini-input" />
                                    <button class="pe-btn-icon-red" @onclick="() => b.PricingPlans.Remove(plan)">
                                        <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    </button>
                                </div>
                            }
                            <button class="pe-btn-add-mini" @onclick='() => b.PricingPlans.Add(new AeroPricingPlan { Name = "New Plan", Price = "$9", Period = "mo" })'>
                                Add Plan
                            </button>
                        </div>
                    </div>
                </div>
