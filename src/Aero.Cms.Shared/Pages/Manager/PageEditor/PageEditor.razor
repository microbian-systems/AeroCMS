    // ── Aero Teams ──────────────────────────────────────────────
    RenderFragment RenderAeroTeamsBlock(EditorBlock b, bool sel) => __builder =>
    {
        var aeroTeams = new AeroTeamsBlock
        {
            Title = b.SectionTitle,
            Description = b.Description,
            Members = b.TeamMembers
        };

        <div class="pe-aero-hero-block @(sel ? "pe-selected" : "")" @onclick="() => SelectBlock(b.EditorId)" @onclick:stopPropagation>
