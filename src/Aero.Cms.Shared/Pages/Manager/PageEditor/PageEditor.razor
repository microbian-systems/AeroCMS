@page "/manager/page/editor"
@page "/manager/page/editor/{id:long}"

@* @layout _PageEditorLayout *@
@using Aero.Cms.Core.Blocks
@using Aero.Cms.Core.Blocks.Common
@using Aero.Cms.Shared.Blocks.Rendering
@using Aero.Cms.Shared.Layout
@using Aero.Cms.Core.Http.Clients
@using Aero.Core.Railway
@using Microsoft.AspNetCore.Components.Sections

@* ── Editor area (Content) ───────────────────────────── *@
@* Note: .pe-editor-area is now provided by ManagerShellLayout *@
@* We just need to handle the internal page header and block container *@

@* Page header (edit mode) *@
@if (!PreviewMode)
{
    <div class="pe-page-header">
        <input class="pe-page-title-input" type="text" placeholder="Page Title"
               value="@PageTitle" @oninput="e => PageTitle = e.Value?.ToString() ?? string.Empty"/>
        <div class="pe-page-meta">
            <div class="pe-meta-left">
                <span class="pe-meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    Last saved: <strong>@LastSaved</strong>
                </span>
                <span class="pe-meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    @Author
                </span>
            </div>
            <div class="pe-meta-right">
                <button class="pe-btn pe-btn-ghost pe-btn-sm" @onclick="TogglePreview">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                    Preview
                </button>
                <button class="pe-btn @(IsSaving ? "pe-btn-secondary" : "pe-btn-primary") pe-btn-sm" @onclick="SavePage" disabled="@IsSaving">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                        <polyline points="17 21 17 13 7 13 7 21"/>
                        <polyline points="7 3 7 8 15 8"/>
                    </svg>
                    @(IsSaving ? "Saving..." : "Save")
                </button>
                <button class="pe-btn pe-btn-success pe-btn-sm" @onclick="PublishPage">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    Publish
                </button>
            </div>
        </div>
    </div>
}

@* Preview device toolbar *@
@if (PreviewMode)
{
    <div class="pe-preview-header">
        <div class="pe-preview-devices">
            <button class="pe-device-btn @(PreviewDevice == "desktop" ? "active" : "")" title="Desktop" @onclick='() => PreviewDevice = "desktop"'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                </svg>
            </button>
            <button class="pe-device-btn @(PreviewDevice == "tablet" ? "active" : "")" title="Tablet" @onclick='() => PreviewDevice = "tablet"'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
                    <line x1="12" y1="18" x2="12.01" y2="18"/>
                </svg>
            </button>
            <button class="pe-device-btn @(PreviewDevice == "mobile" ? "active" : "")" title="Mobile" @onclick='() => PreviewDevice = "mobile"'>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                    <line x1="12" y1="18" x2="12.01" y2="18"/>
                </svg>
            </button>
        </div>
        <button class="pe-btn pe-btn-ghost" @onclick="TogglePreview">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
            Close Preview
        </button>
    </div>
}

@* Blocks canvas *@
<div class="pe-blocks-container @(PreviewMode ? "preview-" + PreviewDevice : "")"
     @ondragover:preventDefault
     @ondrop="OnDropCanvas">

    @* Empty state *@
    @if (Blocks.Count == 0 && !PreviewMode)
    {
        <div class="pe-empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
                 style="cursor: pointer" @onclick="() => RightSidebarCollapsed = false">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <line x1="12" y1="8" x2="12" y2="16"/>
                <line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            <h3>Start building your page</h3>
            <p>Drag blocks from the sidebar or click to add them here</p>
        </div>
    }

    @* Block list *@
    @for (var i = 0; i < Blocks.Count; i++)
    {
        var block = Blocks[i];
        var index = i; // capture for lambda
        var isSelected = SelectedBlockId == block.EditorId;

        <div class="pe-block-wrapper @(isSelected ? "selected" : "") @(DraggedBlockId == block.EditorId ? "dragging" : "") @(DragOverIndex == index ? "drag-over" : "")"
             @onclick="() => SelectBlock(block.EditorId)"
             draggable="true"
             @ondragstart="e => DragStartBlock(e, block.EditorId, index)"
             @ondragover="e => DragOverBlock(e, index)"
             @ondragover:preventDefault
             @ondrop="e => DropBlock(e, index)"
             @ondrop:stopPropagation>

            @* Toolbar *@
            @if (isSelected && !PreviewMode)
            {
                <div class="pe-block-toolbar">
                    <button class="pe-toolbar-btn" title="Move up"
                            disabled="@(index == 0)"
                            @onclick:stopPropagation="true"
                            @onclick="() => MoveBlockUp(index)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="18 15 12 9 6 15"/>
                        </svg>
                    </button>
                    <button class="pe-toolbar-btn" title="Move down"
                            disabled="@(index == Blocks.Count - 1)"
                            @onclick:stopPropagation="true"
                            @onclick="() => MoveBlockDown(index)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </button>
                    <button class="pe-toolbar-btn" title="Duplicate"
                            @onclick:stopPropagation="true"
                            @onclick="() => DuplicateBlock(index)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                    </button>
                    <button class="pe-toolbar-btn delete" title="Delete"
                            @onclick:stopPropagation="true"
                            @onclick="() => DeleteBlock(index)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="3 6 5 6 21 6"/>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                    </button>
                </div>
            }

            <div class="pe-block-content">
                @RenderBlock(block, isSelected)
            </div>
        </div>
    }
</div>

@* Right sidebar content *@
<SectionContent SectionName="RightSidebar">
    <AeroSidebar Title="Blocks" Side="SidebarSide.Right" @bind-IsCollapsed="RightSidebarCollapsed">
        <div class="pe-blocks-sidebar">
            @* Content category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("content")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                    @if (!RightSidebarCollapsed)
                    {
                        @:Dashboard
                        <svg class="pe-chevron @(CategoryContent ? "rotated" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    }
                </button>
                @if (CategoryContent)
                {
                    <div class="pe-category-items">
                        <SidebarBlockItem Label="Hero" @ondragstart='e => DragStart(e, "hero")' OnClick='() => AddBlock("hero")'>
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <line x1="3" y1="9" x2="21" y2="9"/>
                            <line x1="9" y1="21" x2="9" y2="9"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Text" @ondragstart='e => DragStart(e, "text")' OnClick='() => AddBlock("text")'>
                            <polyline points="4 7 4 4 20 4 20 7"/>
                            <line x1="9" y1="20" x2="15" y2="20"/>
                            <line x1="12" y1="4" x2="12" y2="20"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Columns" @ondragstart='e => DragStart(e, "columns")' OnClick='() => AddBlock("columns")'>
                            <rect x="3" y="3" width="7" height="18"/>
                            <rect x="14" y="3" width="7" height="18"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Rich Text" @ondragstart='e => DragStart(e, "content")' OnClick='() => AddBlock("content")'>
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <line x1="3" y1="9" x2="21" y2="9"/>
                            <line x1="9" y1="21" x2="9" y2="9"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Markdown" @ondragstart='e => DragStart(e, "markdown")' OnClick='() => AddBlock("markdown")'>
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Quote" @ondragstart='e => DragStart(e, "quote")' OnClick='() => AddBlock("quote")'>
                            <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Separator" @ondragstart='e => DragStart(e, "separator")' OnClick='() => AddBlock("separator")'>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </SidebarBlockItem>
                    </div>
                }
            </div>
 
            @* Aero Meraki category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("aero")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                    @if (!RightSidebarCollapsed)
                    {
                        @:Aero UX
                        <svg class="pe-chevron @(CategoryAero ? "rotated" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    }
                </button>
                @if (CategoryAero)
                {
                    <div class="pe-category-items">
                        <SidebarBlockItem Title="Hero" Icon="fa-solid fa-star" OnClick='() => CreateBlock("aero_hero")' />
                        <SidebarBlockItem Title="Features" Icon="fa-solid fa-list-check" OnClick='() => CreateBlock("aero_features")' />
                    </div>
                }
            </div>

            @* Media category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("media")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                    </svg>
                    @if (!RightSidebarCollapsed)
                    {
                        @:Media
                        <svg class="pe-chevron @(CategoryMedia ? "rotated" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    }
                </button>
                @if (CategoryMedia)
                {
                    <div class="pe-category-items">
                        <SidebarBlockItem Label="Image" @ondragstart='e => DragStart(e, "image")' OnClick='() => AddBlock("image")'>
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                            <circle cx="8.5" cy="8.5" r="1.5"/>
                            <polyline points="21 15 16 10 5 21"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Video" @ondragstart='e => DragStart(e, "video")' OnClick='() => AddBlock("video")'>
                            <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/>
                            <line x1="7" y1="2" x2="7" y2="22"/>
                            <line x1="17" y1="2" x2="17" y2="22"/>
                            <line x1="2" y1="12" x2="22" y2="12"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Gallery" @ondragstart='e => DragStart(e, "gallery")' OnClick='() => AddBlock("gallery")'>
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                            <circle cx="8.5" cy="8.5" r="1.5"/>
                            <polyline points="21 15 16 10 5 21"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Audio" @ondragstart='e => DragStart(e, "audio")' OnClick='() => AddBlock("audio")'>
                            <path d="M9 18V5l12-2v13"/>
                            <circle cx="6" cy="18" r="3"/>
                            <circle cx="18" cy="16" r="3"/>
                        </SidebarBlockItem>
                    </div>
                }
            </div>

            @* References category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("references")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                    </svg>
                    @if (!RightSidebarCollapsed)
                    {
                        @:References
                        <svg class="pe-chevron @(CategoryReferences ? "rotated" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    }
                </button>
                @if (CategoryReferences)
                {
                    <div class="pe-category-items">
                        <SidebarBlockItem Label="Pages" @ondragstart='e => DragStart(e, "pages")' OnClick='() => AddBlock("pages")'>
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Posts" @ondragstart='e => DragStart(e, "posts")' OnClick='() => AddBlock("posts")'>
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                            <polyline points="10 9 9 9 8 9"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Categories" @ondragstart='e => DragStart(e, "categories")' OnClick='() => AddBlock("categories")'>
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Tags" @ondragstart='e => DragStart(e, "tags")' OnClick='() => AddBlock("tags")'>
                            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                            <line x1="7" y1="7" x2="7.01" y2="7"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="Authors" @ondragstart='e => DragStart(e, "authors")' OnClick='() => AddBlock("authors")'>
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </SidebarBlockItem>
                    </div>
                }
            </div>

            @* Settings category *@
            <div class="pe-category">
                <button class="pe-category-header" @onclick='() => ToggleCategory("settings")'>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1-2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                    @if (!RightSidebarCollapsed)
                    {
                        @:Settings
                        <svg class="pe-chevron @(CategorySettings ? "rotated" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    }
                </button>
                @if (CategorySettings)
                {
                    <div class="pe-category-items">
                        <SidebarBlockItem Label="Page Setup" OnClick='() => CategorySettings = true'>
                            <path d="M12 20h9"/>
                            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="SEO" OnClick='() => CategorySettings = true'>
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </SidebarBlockItem>
                    </div>
                }
            </div>
        </div>
    </AeroSidebar>
</SectionContent>

@* ── Media selector modal ────────────────────────────────── *@
<MediaSelectorModal
    Show="MediaModalOpen"
    MultiSelect="IsGalleryMode"
    Library="MediaLibrary"
    OnClose="() => MediaModalOpen = false"
    OnConfirm="OnConfirmMediaSelection"
    OnUpload="HandleFileSelect"/>

@* ── Toast notifications ─────────────────────────────────── *@
<div class="pe-toast-container">
    @foreach (var toast in Toasts)
    {
        <div class="pe-toast @toast.Type" @onclick="() => RemoveToast(toast.Id)">
            @if (toast.Type == "success")
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
            }
            else if (toast.Type == "error")
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            }
            else
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="16" x2="12" y2="12"/>
                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
            }
            <span>@toast.Message</span>
        </div>
    }
</div>
@* ... (Toasts and Modals retained) ... *@

@* ── Inline render helpers ───────────────────────────────── *@

@code {

    RenderFragment RenderBlock(EditorBlock block, bool isSelected) => block.Type switch
    {
        "hero" => RenderHeroBlock(block, isSelected),
        "aero_hero"     => RenderAeroHeroBlock(block, isSelected),
        "aero_features" => RenderAeroFeaturesBlock(block, isSelected),
        "text" => RenderTextBlock(block),
        "content" => RenderContentBlock(block),
        "markdown" => RenderMarkdownBlock(block),
        "quote" => RenderQuoteBlock(block),
        "separator" => RenderSeparatorBlock(),
        "columns" => RenderColumnsBlock(block, isSelected),
        "image" => RenderImageBlock(block),
        "video" => RenderVideoBlock(block),
        "gallery" => RenderGalleryBlock(block),
        "audio" => RenderAudioBlock(block),
        _ => RenderReferenceBlock(block),
    };

    // ── Hero ───────────────────────────────────────────────────
    RenderFragment RenderHeroBlock(EditorBlock b, bool sel) => __builder =>
    {
        <div class="pe-hero-block"
             style="@(string.IsNullOrEmpty(b.BackgroundImage) ? "" : $"background-image:url({b.BackgroundImage})")">
            @if (!string.IsNullOrEmpty(b.BackgroundImage))
            {
                <div class="pe-hero-overlay"></div>
            }
            <div class="pe-hero-content">
                <input class="pe-hero-title" type="text" placeholder="Main Headline"
                       value="@b.MainText" @oninput="e => b.MainText = e.Value?.ToString() ?? string.Empty"
                       @onfocus="() => SelectBlock(b.EditorId)"/>
                <input class="pe-hero-subtitle" type="text" placeholder="Sub headline or description"
                       value="@b.SubText" @oninput="e => b.SubText = e.Value?.ToString() ?? string.Empty"
                       @onfocus="() => SelectBlock(b.EditorId)"/>
                <div class="pe-hero-cta-row">
                    <input class="pe-hero-cta-text" type="text" placeholder="Button text"
                           value="@b.CtaText" @oninput="e => b.CtaText = e.Value?.ToString() ?? string.Empty"
                           @onfocus="() => SelectBlock(b.EditorId)"/>
                    <input class="pe-hero-cta-url" type="text" placeholder="Button URL"
                           value="@b.CtaUrl" @oninput="e => b.CtaUrl = e.Value?.ToString() ?? string.Empty"
                           @onfocus="() => SelectBlock(b.EditorId)"/>
                </div>
                <div class="pe-hero-bg-controls">
                    @if (string.IsNullOrEmpty(b.BackgroundImage))
                    {
                        <button class="pe-btn pe-btn-secondary pe-btn-sm"
                                @onclick='() => OpenMediaSelector(b, false, "background")'>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                <polyline points="21 15 16 10 5 21"/>
                            </svg>
                            Add Background Image
                        </button>
                    }
                    else
                    {
                        <button class="pe-btn pe-btn-ghost pe-btn-sm"
                                @onclick="() => b.BackgroundImage = string.Empty">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18"/>
                                <line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                            Remove Background
                        </button>
                    }
                </div>
            </div>
        </div>
    };
 
    // ── Aero Hero ──────────────────────────────────────────────
    RenderFragment RenderAeroHeroBlock(EditorBlock b, bool sel) => __builder =>
    {
        var model = new AeroHeroBlock
        {
            Title = b.MainText,
            Description = b.SubText,
            Layout = Enum.TryParse<AeroHeroLayout>(b.AeroLayout, true, out var layout) ? layout : AeroHeroLayout.SideImage,
            Buttons = new List<AeroButton>
            {
                new() { Text = b.CtaText, Url = b.CtaUrl, Style = Enum.TryParse<AeroButtonStyle>(b.Button1Style, true, out var s1) ? s1 : AeroButtonStyle.Primary },
                new() { Text = b.CtaText2, Url = b.CtaUrl2, Style = Enum.TryParse<AeroButtonStyle>(b.Button2Style, true, out var s2) ? s2 : AeroButtonStyle.Secondary }
            },
            BackgroundImage = b.BackgroundImage
        };

        <div class="pe-aero-hero-block @(sel ? "pe-selected" : "")" @onclick:stopPropagation>
             <AeroHeroRenderer Block="model" />
             
             @if (sel && !PreviewMode)
             {
                 <div class="pe-aero-controls">
                     <div class="pe-aero-controls-grid">
                         <div class="pe-control-group">
                             <label>Headline</label>
                             <input type="text" @bind="b.MainText" @bind:event="oninput" placeholder="Main Headline" />
                         </div>
                         <div class="pe-control-group">
                             <label>Description</label>
                             <textarea @bind="b.SubText" @bind:event="oninput" placeholder="Description text..." rows="2"></textarea>
                         </div>
                         <div class="pe-control-group">
                             <label>Layout</label>
                             <select @bind="b.AeroLayout">
                                 <option value="SideImage">Side Image (Left)</option>
                                 <option value="CenterContent">Center Content</option>
                                 <option value="BackgroundImage">Background Image</option>
                             </select>
                         </div>
                          <div class="pe-control-group">
                             <label>Background Image</label>
                             <div class="pe-input-with-btn">
                                 <input type="text" @bind="b.BackgroundImage" placeholder="Image URL..." />
                                 <button class="pe-btn pe-btn-sm" @onclick='() => OpenMediaSelector(b, false, "background")'>
                                     <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                                     </svg>
                                 </button>
                             </div>
                         </div>
                         <div class="pe-control-row">
                             <div class="pe-control-group">
                                 <label>Primary Button</label>
                                 <input type="text" @bind="b.CtaText" placeholder="Label" />
                                 <input type="text" @bind="b.CtaUrl" placeholder="URL (#)" />
                                 <select @bind="b.Button1Style">
                                     <option value="Primary">Primary</option>
                                     <option value="Secondary">Secondary</option>
                                     <option value="Outline">Outline</option>
                                 </select>
                             </div>
                             <div class="pe-control-group">
                                 <label>Secondary Button</label>
                                 <input type="text" @bind="b.CtaText2" placeholder="Label" />
                                 <input type="text" @bind="b.CtaUrl2" placeholder="URL (#)" />
                                 <select @bind="b.Button2Style">
                                     <option value="Primary">Primary</option>
                                     <option value="Secondary">Secondary</option>
                                     <option value="Outline">Outline</option>
                                 </select>
                             </div>
                         </div>
                     </div>
                 </div>
             }
        </div>
    };

    // ── Aero Features ──────────────────────────────────────────
    RenderFragment RenderAeroFeaturesBlock(EditorBlock b, bool sel) => __builder =>
    {
        var aeroFeatures = new AeroFeaturesBlock
        {
            Title = b.MainText,
            SubTitle = b.SubText,
            Layout = Enum.TryParse<AeroFeaturesLayout>(b.AeroLayout, true, out var layout) ? layout : AeroFeaturesLayout.Simple,
            Items = b.FeatureItems
        };

        <div class="pe-aero-hero-block @(sel ? "pe-selected" : "")" @onclick="() => SelectBlock(b.EditorId)" @onclick:stopPropagation>
            <div class="pe-aero-badge">Aero Features</div>
                
            <AeroFeaturesRenderer Block="aeroFeatures" />

            @if (sel && !PreviewMode)
            {
                <div class="pe-aero-controls">
                    <div class="pe-aero-controls-grid">
                        <div class="pe-control-row">
                            <div class="pe-control-group">
                                <label>Section Title</label>
                                <input @bind="b.MainText" @bind:event="oninput" placeholder="Enter title..." />
                            </div>
                            <div class="pe-control-group">
                                <label>Layout</label>
                                <select @bind="b.AeroLayout">
                                    <option value="Simple">Simple</option>
                                    <option value="Centered">Centered</option>
                                    <option value="Cards">Cards</option>
                                    <option value="GridList">Grid List</option>
                                    <option value="Media">Media Grid</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="pe-control-group">
                            <label>Description</label>
                            <textarea @bind="b.SubText" @bind:event="oninput" rows="2" placeholder="Enter description..."></textarea>
                        </div>

                        <div class="pe-features-editor">
                            <label class="pe-label-mini">Feature Items (@b.FeatureItems.Count)</label>
                            <div class="pe-features-list">
                                @foreach (var item in b.FeatureItems)
                                {
                                    <div class="pe-feature-item-row">
                                        <input @bind="item.Title" placeholder="Feature Title" class="pe-mini-input" />
                                        <button class="pe-btn-icon-red" @onclick="() => b.FeatureItems.Remove(item)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                }
                                <button class="pe-btn-add-mini" @onclick='() => b.FeatureItems.Add(new AeroFeatureItem { Title = "New Feature", Description = "Description..." })'>
                                    <i class="fa-solid fa-plus mr-1"></i> Add Feature
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    };

    // ── Plain text ─────────────────────────────────────────────
    RenderFragment RenderTextBlock(EditorBlock b) => __builder =>
    {
        <div class="pe-text-block">
            <textarea placeholder="Enter your text here..."
                      @bind="b.Content"
                      @onfocus="() => SelectBlock(b.EditorId)"></textarea>
        </div>
    };

    // ── Rich content (RadzenHtmlEditor) ────────────────────────
    RenderFragment RenderContentBlock(EditorBlock b) => __builder =>
    {
        <div class="pe-content-block">
            <RadzenHtmlEditor @bind-Value="b.Content" Style="height:300px"/>
        </div>
    };

    // ── Markdown ───────────────────────────────────────────────
    RenderFragment RenderMarkdownBlock(EditorBlock b) => __builder =>
    {
        <div class="pe-markdown-block">
            <div class="pe-markdown-tabs">
                <button class='pe-tab-btn @(b.MarkdownView == "edit" ? "active" : "")'
                        @onclick='() => b.MarkdownView = "edit"'>
                    Edit
                </button>
                <button class='pe-tab-btn @(b.MarkdownView == "preview" ? "active" : "")'
                        @onclick='() => b.MarkdownView = "preview"'>
                    Preview
                </button>
            </div>
            @if (b.MarkdownView == "edit")
            {
                <textarea placeholder="# Markdown content..."
                          @bind="b.Content"
                          @onfocus="() => SelectBlock(b.EditorId)"></textarea>
            }
            else
            {
                <div class="pe-markdown-preview">@((MarkupString)RenderMarkdown(b.Content))</div>
            }
        </div>
    };

    // ── Quote ──────────────────────────────────────────────────
    RenderFragment RenderQuoteBlock(EditorBlock b) => __builder =>
    {
        <div class="pe-quote-block">
            <blockquote>
                <textarea placeholder="Enter quote text..."
                          @bind="b.Content"
                          @onfocus="() => SelectBlock(b.EditorId)"></textarea>
            </blockquote>
            <input class="pe-quote-author" type="text" placeholder="Author name"
                   @bind="b.Author"
                   @onfocus="() => SelectBlock(b.EditorId)"/>
        </div>
    };

    // ── Separator ──────────────────────────────────────────────
    RenderFragment RenderSeparatorBlock() => __builder => { <hr class="pe-separator-block"/> };

    // ── Columns ────────────────────────────────────────────────
    RenderFragment RenderColumnsBlock(EditorBlock b, bool sel) => __builder =>
    {
        <div class="pe-columns-block-wrapper">
            @if (sel && !PreviewMode)
            {
                <div class="pe-columns-controls">
                    <div class="pe-col-ctrl">
                        <label>Columns: @b.ColumnCount</label>
                        <input type="range" min="1" max="12"
                               value="@b.ColumnCount"
                               @oninput='e => UpdateColumnCount(b, int.Parse(e.Value?.ToString() ?? "2"))'/>
                    </div>
                    <div class="pe-col-ctrl">
                        <label>Gap: @(b.Gap)px</label>
                        <input type="range" min="0" max="64"
                               value="@b.Gap"
                               @oninput='e => b.Gap = int.Parse(e.Value?.ToString() ?? "16")'/>
                    </div>
                </div>
            }
            <div class="pe-columns-block" style="gap:@(b.Gap)px">
                @for (var ci = 0; ci < b.EditorColumns.Count; ci++)
                {
                    var col = b.EditorColumns[ci];
                    var colIndex = ci;
                    <div class="pe-column"
                         style="flex: 0 0 calc(@(100.0 / b.ColumnCount)% - @(b.Gap * (b.ColumnCount - 1.0) / b.ColumnCount)px)"
                         @ondragover:preventDefault
                         @ondrop="e => DropOnColumn(e, b, colIndex)">
                        @if (sel && !PreviewMode)
                        {
                            <div class="pe-column-header">
                                <span class="pe-column-label">Col @(colIndex + 1)</span>
                                <button class="pe-column-add-btn" title="Add text"
                                        @onclick='() => AddBlockToColumn(b, colIndex, "text")'>
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="12" y1="5" x2="12" y2="19"/>
                                        <line x1="5" y1="12" x2="19" y2="12"/>
                                    </svg>
                                </button>
                            </div>
                        }
                        <div class="pe-column-content">
                            @for (var ni = 0; ni < col.Blocks.Count; ni++)
                            {
                                var nb = col.Blocks[ni];
                                var nestedIndex = ni;
                                <div class="pe-nested-block">
                                    @RenderNestedBlock(nb, b, colIndex)
                                    @if (sel && !PreviewMode)
                                    {
                                        <button class="pe-remove-nested-btn"
                                                @onclick="() => RemoveNestedBlock(b, colIndex, nestedIndex)">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <line x1="18" y1="6" x2="6" y2="18"/>
                                                <line x1="6" y1="6" x2="18" y2="18"/>
                                            </svg>
                                        </button>
                                    }
                                </div>
                            }
                            @if (col.Blocks.Count == 0 && sel && !PreviewMode)
                            {
                                <div class="pe-column-drop-hint">
                                    <span>Drag blocks here or click + to add</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    };

    RenderFragment RenderNestedBlock(NestedBlock nb, EditorBlock parent, int colIndex) => __builder =>
    {
        switch (nb.Type)
        {
            case "text":
                <textarea @bind="nb.Content" placeholder="Text..." rows="3"></textarea>
                break;
            case "image":
                <div class="pe-nested-image">
                    @if (string.IsNullOrEmpty(nb.Src))
                    {
                        <button class="pe-add-nested-btn"
                                @onclick="() => OpenMediaSelectorForNested(parent, colIndex, nb)">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="18" height="18" rx="2"/>
                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                <polyline points="21 15 16 10 5 21"/>
                            </svg>
                        </button>
                    }
                    else
                    {
                        <img src="@nb.Src" alt="@nb.Alt"/>
                    }
                </div>
                break;
            case "video":
                <div class="pe-nested-video">
                    @if (string.IsNullOrEmpty(nb.Src))
                    {
                        <input type="text" placeholder="Video URL" @bind="nb.Url"
                               @onkeydown='e => { if (e.Key == "Enter") LoadNestedVideo(nb); }'/>
                    }
                    else
                    {
                        <iframe src="@nb.Src" frameborder="0" allowfullscreen></iframe>
                    }
                </div>
                break;
            case "button":
                <div class="pe-nested-button-editor">
                    <input type="text" placeholder="Button text" @bind="nb.Text"/>
                    <input type="text" placeholder="URL" @bind="nb.Url"/>
                    <select @bind="nb.Style">
                        <option value="primary">Primary</option>
                        <option value="secondary">Secondary</option>
                        <option value="outline">Outline</option>
                    </select>
                </div>
                break;
        }
    };

    // ── Image ──────────────────────────────────────────────────
    RenderFragment RenderImageBlock(EditorBlock b) => __builder =>
    {
        <div class="pe-image-block">
            @if (string.IsNullOrEmpty(b.Src))
            {
                <button class="pe-add-media-btn" @onclick="() => OpenMediaSelector(b)">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                    </svg>
                    <span>Add Image</span>
                </button>
            }
            else
            {
                <div class="pe-image-wrapper">
                    <img src="@b.Src" alt="@b.Alt"/>
                    <div class="pe-image-overlay">
                        <button class="pe-overlay-btn" @onclick="() => OpenMediaSelector(b)">Change</button>
                        <button class="pe-overlay-btn delete" @onclick="() => RemoveImage(b)">Remove</button>
                    </div>
                    <input class="pe-image-caption" type="text" placeholder="Add caption..."
                           @bind="b.Caption"/>
                </div>
            }
        </div>
    };

    // ── Video ──────────────────────────────────────────────────
    RenderFragment RenderVideoBlock(EditorBlock b) => __builder =>
    {
        <div class="pe-video-block">
            @if (string.IsNullOrEmpty(b.Src))
            {
                <div class="pe-video-input">
                    <input type="text" placeholder="Enter video URL (YouTube, Vimeo, or direct link)"
                           @bind="b.Url"/>
                    <button class="pe-btn pe-btn-primary" @onclick="() => LoadVideo(b)">Add Video</button>
                </div>
            }
            else
            {
                <div class="pe-video-wrapper">
                    <iframe src="@b.Src" frameborder="0" allowfullscreen></iframe>
                    <button class="pe-remove-video" @onclick="() => RemoveVideo(b)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>
            }
        </div>
    };

    // ── Gallery ────────────────────────────────────────────────
    RenderFragment RenderGalleryBlock(EditorBlock b) => __builder =>
    {
        <div class="pe-gallery-block">
            <div class="pe-gallery-grid">
                @for (var gi = 0; gi < b.GalleryImages.Count; gi++)
                {
                    var img = b.GalleryImages[gi];
                    var imgIndex = gi;
                    <div class="pe-gallery-item">
                        <img src="@img.Src" alt="@img.Alt"/>
                        <button class="pe-remove-item" @onclick="() => b.GalleryImages.RemoveAt(imgIndex)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18"/>
                                <line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                        </button>
                    </div>
                }
                <button class="pe-add-gallery-item" @onclick="() => OpenMediaSelector(b, true)">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                </button>
            </div>
        </div>
    };

    // ── Audio ──────────────────────────────────────────────────
    RenderFragment RenderAudioBlock(EditorBlock b) => __builder =>
    {
        <div class="pe-audio-block">
            @if (string.IsNullOrEmpty(b.Src))
            {
                <button class="pe-add-media-btn" @onclick="() => OpenAudioSelector(b)">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M9 18V5l12-2v13"/>
                        <circle cx="6" cy="18" r="3"/>
                        <circle cx="18" cy="16" r="3"/>
                    </svg>
                    <span>Add Audio</span>
                </button>
            }
            else
            {
                <div class="pe-audio-wrapper">
                    <audio controls src="@b.Src" style="flex:1"></audio>
                    <button class="pe-remove-audio" @onclick="() => b.Src = string.Empty">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>
            }
        </div>
    };

    // ── Reference blocks ───────────────────────────────────────
    RenderFragment RenderReferenceBlock(EditorBlock b) => __builder =>
    {
        var items = GetReferenceItems(b.Type);
        <div class="pe-reference-block">
            <div class="pe-reference-header">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    @if (b.Type == "pages" || b.Type == "posts")
                    {
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    }
                    else if (b.Type == "categories")
                    {
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                    }
                    else if (b.Type == "tags")
                    {
                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                    }
                    else
                    {
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    }
                </svg>
                <span>@(char.ToUpper(b.Type[0]) + b.Type[1..]) Reference</span>
            </div>
            <select value="@b.SelectedReferenceId"
                    @onchange="e => b.SelectedReferenceId = e.Value?.ToString() ?? string.Empty">
                <option value="">Select @b.Type…</option>
                @foreach (var item in items)
                {
                    <option value="@item.Id">@(item.Title ?? item.Name)</option>
                }
            </select>
            @if (!string.IsNullOrEmpty(b.SelectedReferenceId))
            {
                @RenderReferencePreview(b, items)
            }
        </div>
    };

    RenderFragment RenderReferencePreview(EditorBlock b, List<ReferenceItem> items) => __builder =>
    {
        var item = items.FirstOrDefault(i => i.Id == b.SelectedReferenceId);
        if (item is null) return;

        if (b.Type is "pages" or "posts")
        {
            <div class="pe-reference-card">
                <h4>@item.Title</h4>
                <span class="pe-reference-type">@b.Type[..^1]</span>
            </div>
        }
        else if (b.Type == "authors")
        {
            <div class="pe-reference-card pe-author-card">
                <div class="pe-author-avatar">@(item.Name?[..1])</div>
                <span>@item.Name</span>
            </div>
        }
        else
        {
            <div class="pe-reference-card">
                <span class="pe-tag-name">@item.Name</span>
            </div>
        }
    };

    // inline helper – call from SidebarBlockItem via ChildContent
    RenderFragment<string> SidebarIcon => label => __builder => { };


}
