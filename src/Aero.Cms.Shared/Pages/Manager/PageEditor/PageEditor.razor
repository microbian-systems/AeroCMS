                                          @ondragstart='e => DragStart(e, "aero_testimonials")'
                                          OnClick='() => AddBlock("aero_testimonials")'>
                            
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                            
                        </SidebarBlockItem>
                        <SidebarBlockItem Label="FAQ" 
                                          @ondragstart='e => DragStart(e, "aero_faq")'
                                          OnClick='() => AddBlock("aero_faq")'>
                            
