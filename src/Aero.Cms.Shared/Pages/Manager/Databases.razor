@page "/manager/databases"

<PageTitle>Databases - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">Infrastructure: Data Nodes</h1>
        <div class="flex space-x-2">
            <span class="px-3 py-1 bg-emerald-100 text-emerald-700 rounded-full font-bold text-[10px] uppercase font-mono">cluster: healthy</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full font-bold text-[10px] uppercase font-mono">nodes: 4</span>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-8 bg-white border border-gray-200 rounded-2xl shadow-sm">
            <div class="flex items-center space-x-3 mb-4">
                <div class="p-2 bg-indigo-50 text-indigo-600 rounded-lg"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 4.48 4 10 4s10-1.79 10-4V7M4 7c0 2.21 4.48 4 10 4s10-1.79 10-4M4 7c0-2.21 4.48-4 10-4s10 1.79 10 4m0 5c0 2.21-4.48 4-10 4s-10-1.79-10-4"/></svg></div>
                <h3 class="text-lg font-bold text-gray-900">PostgreSQL Cloud Cluster</h3>
            </div>
            <p class="text-sm text-gray-500 mb-6 font-semibold italic">Primary persistent data orchestration node for global reach.</p>
            <div class="space-y-3">
                <div class="flex items-center justify-between text-xs py-2 border-b border-gray-50">
                    <span class="text-gray-400 font-bold uppercase tracking-widest text-[10px]">Host</span>
                    <span class="text-gray-900 font-mono">psql-node-01.aero-cloud.internal</span>
                </div>
                <div class="flex items-center justify-between text-xs py-2 border-b border-gray-50">
                    <span class="text-gray-400 font-bold uppercase tracking-widest text-[10px]">Storage</span>
                    <span class="text-gray-900">842 GB / 2 TB</span>
                </div>
                <div class="flex items-center justify-between text-xs py-2 border-b border-gray-50">
                    <span class="text-gray-400 font-bold uppercase tracking-widest text-[10px]">Uptime</span>
                    <span class="text-emerald-600 font-bold">99.98%</span>
                </div>
            </div>
        </div>

        <div class="p-8 bg-white border border-gray-200 rounded-2xl shadow-sm">
            <div class="flex items-center space-x-3 mb-4">
                <div class="p-2 bg-rose-50 text-rose-600 rounded-lg"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg></div>
                <h3 class="text-lg font-bold text-gray-900">RavenDB Distributed Cache</h3>
            </div>
            <p class="text-sm text-gray-500 mb-6 italic leading-relaxed">Extreme high-performance read-layer cache for enterprise telemetry scaling.</p>
            <div class="space-y-3">
                <div class="flex items-center justify-between text-xs py-2 border-b border-gray-50">
                    <span class="text-gray-400 font-bold uppercase tracking-widest text-[10px]">Status</span>
                    <span class="text-emerald-600 font-bold uppercase tracking-widest text-[10px]">Synchronized</span>
                </div>
                <div class="flex items-center justify-between text-xs py-2 border-b border-gray-50">
                    <span class="text-gray-400 font-bold uppercase tracking-widest text-[10px]">Requests/sec</span>
                    <span class="text-gray-900 font-bold">14,242 req/s</span>
                </div>
            </div>
        </div>
    </div>
</div>
