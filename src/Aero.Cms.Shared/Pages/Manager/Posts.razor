@page "/manager/posts"

<PageTitle>Posts - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Content Pipeline: Posts</h1>
            <p class="text-sm text-gray-500 mt-1">Centralized blog and news article orchestration.</p>
        </div>
        <button class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-semibold shadow-sm hover:bg-indigo-700 transition-all flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            <span>Draft New Post</span>
        </button>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50 uppercase text-[10px] font-bold tracking-widest text-gray-400">
                <tr>
                    <th class="px-6 py-3 text-left">Article Details</th>
                    <th class="px-6 py-3 text-left">Status</th>
                    <th class="px-6 py-3 text-left">Scheduled</th>
                    <th class="px-6 py-3 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-100">
                <tr>
                    <td class="px-6 py-4">
                        <div class="font-bold text-gray-900">Modern C# Architectures 2026</div>
                        <p class="text-[10px] text-gray-500">Author: Lena K. • 1.2k views</p>
                    </td>
                    <td class="px-6 py-4">
                         <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-green-100 text-green-700 uppercase">Live</span>
                    </td>
                    <td class="px-6 py-4 text-xs text-gray-500">Mar 22, 14:00</td>
                    <td class="px-6 py-4 text-right">
                        <button class="text-indigo-600 font-bold text-xs hover:underline">Edit</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
