@page "/manager/store"

<PageTitle>Mix Store - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
         <h1 class="text-2xl font-bold text-gray-900 leading-tight italic tracking-tight italic tracking-tight uppercase tracking-tight">Enterprise Asset Marketplace</h1>
         <div class="flex space-x-2">
            <span class="px-3 py-1 bg-rose-100 text-rose-700 rounded-full font-bold text-[10px] uppercase font-mono italic">Market Hub Connected</span>
         </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @for (int i = 1; i <= 6; i++) {
        <div class="bg-white border border-gray-200 rounded-3xl p-8 shadow-sm hover:shadow-2xl transition-all cursor-pointer group hover:-translate-y-1">
             <div class="w-12 h-12 rounded-2xl bg-gradient-to-br @(i % 3 == 0 ? "from-indigo-50 to-indigo-200 text-indigo-600" : i % 3 == 1 ? "from-rose-50 to-rose-200 text-rose-600" : "from-emerald-50 to-emerald-200 text-emerald-600") flex items-center justify-center mb-6 shadow-inner">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
             </div>
             <h4 class="font-bold text-lg text-gray-900 group-hover:text-indigo-600 transition-colors uppercase italic leading-tight">Module Extension P@(i * 12)</h4>
             <p class="text-[10px] text-gray-400 font-mono mt-1 mb-4">By Aero Core Labs</p>
             <div class="text-xs text-gray-500 italic mb-6 leading-relaxed">High-performance enterprise extension for global scaling reach.</div>
             <div class="flex items-center justify-between border-t border-gray-50 pt-6">
                <span class="text-sm font-bold text-gray-900">$@(i * 99).00</span>
                <button class="px-4 py-2 bg-indigo-600 text-white rounded-xl text-[10px] font-bold uppercase tracking-widest hover:bg-indigo-700 transition-colors">Install Extension</button>
             </div>
        </div>
        }
    </div>
</div>
