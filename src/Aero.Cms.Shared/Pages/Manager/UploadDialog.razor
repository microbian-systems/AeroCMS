@using Aero.Cms.Core.Http.Clients
@using Aero.Core
@using Aero.Core.Railway
@using Radzen
@using Radzen.Blazor
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject IMediaHttpClient MediaClient
@inject NotificationService NotificationService
@inject DialogService DialogService
@using Microsoft.Extensions.Logging
@inject ILogger<UploadDialog> Logger

<div class="media-upload-dialog p-6 bg-white dark:bg-gray-900 rounded-3xl">
    <div class="mb-8 flex items-center justify-between">
        <div class="flex flex-col">
            <h3 class="text-xl font-black text-gray-900 dark:text-white tracking-tight">Upload Assets</h3>
            <p class="text-xs text-gray-500 font-medium mt-1">Add images, videos, or documents to your library</p>
        </div>
        <div class="bg-indigo-50 dark:bg-indigo-900/20 px-3 py-1.5 rounded-full border border-indigo-100 dark:border-indigo-900/30">
            <span class="text-[10px] font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest">Max 10MB</span>
        </div>
    </div>

    <!-- Premium Custom Input Dropzone -->
    <div class="relative group">
        <InputFile OnChange="@OnInputFileChange" multiple class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" id="fileInput" />
        
        <div class="w-full h-48 flex flex-col items-center justify-center border-2 border-dashed border-gray-100 dark:border-gray-800 rounded-3xl bg-gray-50 dark:bg-gray-900/50 group-hover:bg-white dark:group-hover:bg-gray-800 group-hover:border-indigo-400 dark:group-hover:border-indigo-900 transition-all duration-300 relative overflow-hidden">
            <!-- Animated Background Glow -->
            <div class="absolute -top-24 -left-24 w-48 h-48 bg-indigo-500/10 blur-[80px] rounded-full group-hover:bg-indigo-500/20 transition-all"></div>
            <div class="absolute -bottom-24 -right-24 w-48 h-48 bg-purple-500/10 blur-[80px] rounded-full group-hover:bg-purple-500/20 transition-all"></div>

            <div class="flex flex-col items-center gap-4 relative z-0">
                <div class="w-16 h-16 bg-white dark:bg-gray-800 rounded-2xl shadow-xl shadow-indigo-500/10 flex items-center justify-center transform group-hover:-translate-y-1 transition-transform duration-300">
                    <RadzenIcon Icon="@("cloud_upload")" class="w-8 h-8 text-indigo-500" />
                </div>
                <div class="flex flex-col items-center">
                    <span class="text-sm font-bold text-gray-700 dark:text-gray-300">Click to browse or drag & drop</span>
                    <span class="text-[10px] text-gray-400 font-medium mt-1 uppercase tracking-widest">SVG, PNG, JPG or PDF</span>
                </div>
            </div>
        </div>
    </div>

    @if (selectedFiles.Any())
    {
        <div class="mt-8 space-y-3 max-h-60 overflow-y-auto pr-2 scrollbar-thin">
            <div class="flex items-center justify-between mb-2">
                <h4 class="text-[10px] font-black uppercase tracking-widest text-gray-400">Queue (@selectedFiles.Count)</h4>
                <RadzenButton Text="@("Clear All")" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" Click="@(() => selectedFiles.Clear())" class="text-[10px]" />
            </div>
            
            @foreach (var file in selectedFiles)
            {
                <div class="flex items-center justify-between p-3.5 bg-gray-50 dark:bg-gray-800/50 rounded-2xl border border-gray-100 dark:border-gray-800 transition-colors hover:border-indigo-100 dark:hover:border-indigo-900/30">
                    <div class="flex items-center flex-1 min-w-0">
                        <div class="w-9 h-9 bg-white dark:bg-gray-800 rounded-xl flex items-center justify-center mr-3 shadow-sm border border-gray-50 dark:border-gray-700">
                            <RadzenIcon Icon="@("insert_drive_file")" class="text-gray-400 w-5 h-5" />
                        </div>
                        <div class="flex flex-col min-w-0 pr-4">
                            <span class="text-xs font-bold text-gray-700 dark:text-gray-200 truncate">@file.Name</span>
                            <span class="text-[10px] text-gray-400 font-mono">@FormatSize(file.Size)</span>
                        </div>
                    </div>
                    @if (isUploading)
                    {
                         <RadzenProgressBar Circular="true" Value="100" Mode="ProgressBarMode.Indeterminate" Style="@("width: 18px; height: 18px")" />
                    }
                    else
                    {
                         <RadzenButton Icon="@("close")" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Click="@(() => RemoveFile(file))" class="rounded-full hover:bg-red-50 dark:hover:bg-red-900/20 hover:text-red-500 transition-colors" />
                    }
                </div>
            }
        </div>
    }

    <div class="mt-8 pt-6 border-t border-gray-100 dark:border-gray-800 flex justify-end gap-3">
        <RadzenButton Text="@("Close")" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" class="rounded-xl px-6 font-bold text-xs" Click="@(() => DialogService.Close(successCount > 0))" />
        <RadzenButton Text="@(isUploading ? "Uploading..." : "Publish Assets")" Icon="@("rocket_launch")" ButtonStyle="ButtonStyle.Primary" 
                     Variant="Variant.Filled" class="rounded-xl px-8 shadow-xl shadow-indigo-500/20 font-bold text-xs py-2.5" 
                     Click="@OnUpload" Disabled="@(!selectedFiles.Any() || isUploading)" />
    </div>
</div>

@code {
    [Parameter] public long? ParentId { get; set; }
    List<IBrowserFile> selectedFiles = new();
    bool isUploading;
    int successCount;

    void OnInputFileChange(InputFileChangeEventArgs args)
    {
        Logger.LogInformation("File input change detected. Selected {Count} files.", args.FileCount);
        foreach (var file in args.GetMultipleFiles(20))
        {
            if (!selectedFiles.Any(f => f.Name == file.Name && f.Size == file.Size))
            {
                selectedFiles.Add(file);
            }
        }
    }

    void RemoveFile(IBrowserFile file)
    {
        selectedFiles.Remove(file);
    }

    async Task OnUpload()
    {
        if (!selectedFiles.Any()) return;
        
        isUploading = true;
        successCount = 0;

        foreach (var file in selectedFiles.ToList())
        {
            Logger.LogInformation("Processing upload for {FileName} ({Size} bytes)", file.Name, file.Size);
            try 
            {
                using var stream = file.OpenReadStream(10 * 1024 * 1024); // max 10MB
                using var memoryStream = new MemoryStream();
                
                Logger.LogDebug("Copying {FileName} to memory stream...", file.Name);
                await stream.CopyToAsync(memoryStream);
                
                var data = memoryStream.ToArray();
                Logger.LogDebug("Finished reading file. Size: {Bytes} bytes. Converting to Base64...", data.Length);
                
                var base64 = Convert.ToBase64String(data);
                var req = new UploadMediaRequest(file.Name, file.ContentType, file.Size, null, null, ParentId, base64);
                
                Logger.LogInformation("Invoking MediaClient.UploadAsync for {FileName}...", file.Name);
                var result = await MediaClient.UploadAsync(req);

                if (result is Result<MediaDetail, AeroError>.Ok ok)
                {
                    Logger.LogInformation("Successfully uploaded {FileName}. Assigned ID: {Id}", file.Name, ok.Value.Id);
                    successCount++;
                    selectedFiles.Remove(file);
                }
                else if (result is Result<MediaDetail, AeroError>.Failure fail)
                {
                    Logger.LogError("API Error during upload of {FileName}: {Error}", file.Name, fail.Error.ToString());
                    NotificationService.Notify(NotificationSeverity.Error, "Upload Failed", $"API Error: {fail.Error}");
                }
            }
            catch (Exception ex)
            {
                Logger.LogCritical(ex, "Unexpected crash during upload of {FileName}", file.Name);
                NotificationService.Notify(NotificationSeverity.Error, "Upload Failed", $"Error uploading {file.Name}: {ex.Message}");
            }
        }

        isUploading = false;
        if (successCount > 0)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Upload Complete", $"Successfully uploaded {successCount} files.");
            if (!selectedFiles.Any())
            {
                DialogService.Close(true);
            }
        }
    }

    string FormatSize(long bytes)
    {
        string[] suffix = { "B", "KB", "MB", "GB", "TB" };
        int i;
        double dblSByte = bytes;
        for (i = 0; i < suffix.Length && bytes >= 1024; i++, bytes /= 1024)
        {
            dblSByte = bytes / 1024.0;
        }
        return $"{dblSByte:0.##} {suffix[i]}";
    }
}
