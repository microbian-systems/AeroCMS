@page "/manager/settings"

<PageTitle>Settings - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
         <h1 class="text-2xl font-bold text-gray-900 leading-tight italic tracking-tight uppercase tracking-tight italic">Platform Governance: Settings</h1>
         <button class="px-6 py-2 bg-indigo-600 text-white rounded-xl font-bold font-semibold shadow-sm hover:bg-indigo-700 transition-all text-xs uppercase tracking-widest">Apply Governance Policy</button>
    </div>

    <div class="bg-white border border-gray-200 rounded-3xl p-8 shadow-sm flex flex-col divide-y divide-gray-100">
        <div class="py-6 flex items-center justify-between hover:bg-gray-50/50 transition-colors px-4 group">
             <div>
                <h4 class="font-bold text-lg italic tracking-tight uppercase leading-tight group-hover:text-indigo-600 transition-colors">Enterprise Security Mode</h4>
                <p class="text-xs text-gray-400 mt-1 italic leading-relaxed">Multi-factor identity orchestration and session isolation node.</p>
             </div>
             <div class="w-14 h-8 bg-emerald-500 rounded-full p-1 flex items-center shadow-inner cursor-pointer hover:bg-emerald-600 transition-colors">
                 <div class="w-6 h-6 bg-white rounded-full ml-auto shadow-sm"></div>
             </div>
        </div>

        <div class="py-6 flex items-center justify-between hover:bg-gray-50/50 transition-colors px-4 group">
             <div>
                <h4 class="font-bold text-lg italic tracking-tight uppercase leading-tight group-hover:text-indigo-600 transition-colors">System Telemetry Bridge</h4>
                <p class="text-xs text-gray-400 mt-1 italic leading-relaxed">Real-time infrastructure health and logging reach automation.</p>
             </div>
             <div class="w-14 h-8 bg-gray-200 rounded-full p-1 flex items-center shadow-inner cursor-pointer hover:bg-indigo-500 transition-colors group/toggle">
                 <div class="w-6 h-6 bg-white rounded-full shadow-sm group-hover/toggle:translate-x-6 transition-transform"></div>
             </div>
        </div>

        <div class="py-6 flex items-center justify-between hover:bg-gray-50/50 transition-colors px-4 group">
             <div>
                <h4 class="font-bold text-lg italic tracking-tight uppercase leading-tight group-hover:text-indigo-600 transition-colors">Content Pipeline Caching</h4>
                 <p class="text-xs text-gray-400 mt-1 italic leading-relaxed">RavenDB distributed cache sync and event-driven invalidation.</p>
             </div>
             <div class="w-14 h-8 bg-emerald-500 rounded-full p-1 flex items-center shadow-inner cursor-pointer hover:bg-emerald-600 transition-colors">
                 <div class="w-6 h-6 bg-white rounded-full ml-auto shadow-sm"></div>
             </div>
        </div>
    </div>
</div>
