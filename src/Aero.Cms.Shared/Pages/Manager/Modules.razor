@page "/manager/modules"

<PageTitle>Modules - Aero CMS</PageTitle>

<div class="space-y-6">
    <h1 class="text-2xl font-bold text-gray-900">Module Ecosystem</h1>
    <p class="text-sm text-gray-500 mt-1 italic">Extensible micro-service based plugin architecture.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-indigo-600 p-6 rounded-2xl text-white shadow-xl shadow-indigo-100 flex flex-col justify-between h-48">
            <div>
                <h4 class="font-bold text-lg">Marten Content</h4>
                <p class="text-[10px] text-indigo-100 uppercase tracking-widest mt-1 italic font-mono uppercase">core architecture</p>
                <div class="text-xs text-indigo-100 mt-4 leading-relaxed font-semibold">Native event-driven document store for high-performance content orchestration.</div>
            </div>
            <div class="flex items-center space-x-2">
                <span class="w-2 h-2 rounded-full bg-indigo-300"></span>
                <span class="text-[10px] font-bold uppercase tracking-widest">Active System Module</span>
            </div>
        </div>
        
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm hover:border-indigo-400 transition-colors cursor-pointer group h-48 flex flex-col justify-between">
            <div>
                <h4 class="font-bold text-lg text-gray-900 group-hover:text-indigo-600">Enterprise Asset Mgmt.</h4>
                <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-1">asset cloud bridge</p>
                <div class="text-xs text-gray-500 mt-4 leading-relaxed italic">Cloud-ready media and file storage orchestration with CDN integration.</div>
            </div>
            <div class="flex items-center space-x-2">
                <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Connected Expansion</span>
            </div>
        </div>
    </div>
</div>
