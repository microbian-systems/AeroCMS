@page "/manager/categories"

<PageTitle>Categories - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900 leading-tight">Content Taxonomy: Categories</h1>
        <button class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-semibold shadow-sm hover:bg-indigo-700 transition-all flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <span>Classify New Segment</span>
        </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="p-6 bg-white border border-gray-200 rounded-xl shadow-sm border-l-4 border-l-indigo-600">
            <h4 class="font-bold text-gray-900 uppercase text-xs tracking-widest italic mb-2">Architectures</h4>
            <div class="flex items-center justify-between mt-4">
                <span class="text-xs text-gray-500 font-bold">128 Items Organized</span>
                <span class="text-2xl font-bold text-indigo-600">8.2k<span class="text-[10px] text-gray-400 ml-1">v/d</span></span>
            </div>
        </div>
        <div class="p-6 bg-white border border-gray-200 rounded-xl shadow-sm border-l-4 border-l-rose-500">
            <h4 class="font-bold text-gray-900 uppercase text-xs tracking-widest italic mb-2">Enterprise Strategy</h4>
            <div class="flex items-center justify-between mt-4">
                <span class="text-xs text-gray-500 font-bold">42 Items Organized</span>
                <span class="text-2xl font-bold text-rose-500">4.1k<span class="text-[10px] text-gray-400 ml-1">v/d</span></span>
            </div>
        </div>
    </div>
</div>
