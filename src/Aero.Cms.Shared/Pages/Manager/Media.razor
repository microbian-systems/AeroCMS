@page "/manager/media"

<PageTitle>Media - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900 leading-tight italic tracking-tight">Enterprise Asset Hub</h1>
        <button class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-semibold shadow-sm hover:bg-indigo-700 transition-all flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
            <span>Ingest Media Bin</span>
        </button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
        @for (int i = 1; i <= 10; i++) {
        <div class="group bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-xl transition-all h-64 flex flex-col cursor-pointer">
            <div class="flex-1 bg-gray-50 flex items-center justify-center p-8 bg-gradient-to-br from-gray-50 to-indigo-50 group-hover:from-indigo-100 transition-colors">
                <svg class="w-12 h-12 text-gray-300 group-hover:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div class="p-4 border-t border-gray-100 flex items-center justify-between">
                <div>
                    <h5 class="text-[10px] font-bold text-gray-900 truncate uppercase tracking-widest italic leading-tight">asset-v6-cloud.webp</h5>
                    <p class="text-[10px] text-gray-400 font-mono">1.2 MB • WEBP</p>
                </div>
            </div>
        </div>
        }
    </div>
</div>
