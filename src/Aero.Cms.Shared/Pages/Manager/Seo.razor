@page "/manager/seo"
@page "/manager/seo/general"

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">SEO Analysis</h1>
            <p class="mt-1 text-sm text-gray-500">Analyze your site's SEO score and optimization status.</p>
        </div>
        <RadzenButton Icon="analytics" Text="Start Full Scan" ButtonStyle="ButtonStyle.Primary" />
    </div>

    <RadzenCard class="p-8 flex flex-col items-center justify-center space-y-4">
        <RadzenText TextStyle="TextStyle.H2" class="font-bold text-gray-300">TBD</RadzenText>
        <RadzenText TextStyle="TextStyle.Subtitle1" class="text-gray-500">SEO scoring and status surface is currently in development.</RadzenText>
        <div class="w-full max-w-md">
            <RadzenProgressBar Value="0" ShowValue="false" />
        </div>
    </RadzenCard>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        @for (int i = 1; i <= 3; i++)
        {
            <RadzenCard class="opacity-50">
                <RadzenText TextStyle="TextStyle.H6">Metric @i</RadzenText>
                <div class="h-24 flex items-center justify-center border-2 border-dashed border-gray-100 rounded mt-2">
                    <span class="text-xs text-gray-400">Loading data...</span>
                </div>
            </RadzenCard>
        }
    </div>
</div>

