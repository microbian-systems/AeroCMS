@page "/manager/users"

<PageTitle>Users - Aero CMS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900 italic tracking-tight uppercase leading-tight">Identity Orchesration</h1>
        <button class="px-4 py-2 bg-indigo-600 text-white rounded-lg font-semibold shadow-sm hover:bg-indigo-700 transition-all flex items-center space-x-2">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
            <span>Invite Enterprise User</span>
        </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @for (int i = 1; i <= 6; i++) {
        <div class="p-6 bg-white border border-gray-200 rounded-2xl shadow-sm hover:shadow-lg transition-all border-t-2 border-t-indigo-600">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br @(i % 2 == 0 ? "from-indigo-100 to-indigo-300" : "from-rose-100 to-rose-300") shadow-inner"></div>
                <div>
                    <h5 class="text-sm font-bold text-gray-900 truncate uppercase mt-0.5 tracking-widest italic">User Agent @(i * 42)</h5>
                    <p class="text-[10px] text-gray-400 font-mono">Role: Enterprise Admin</p>
                </div>
            </div>
            <div class="mt-6 flex flex-col space-y-2 border-t border-gray-100 pt-4">
               <button class="text-xs font-bold text-indigo-600 hover:underline uppercase tracking-widest text-left">Grant Elevation</button>
               <button class="text-xs font-bold text-gray-400 hover:text-red-500 uppercase tracking-widest text-left">Revoke Session</button>
            </div>
        </div>
        }
    </div>
</div>
