@using Aero.Cms.Core.Blocks.Common
@using Aero.Cms.Core.Blocks

@if (Block != null)
{
    <section class="bg-white dark:bg-gray-900">
        <div class="flex justify-center h-screen">
            @if (Block.Layout == AeroAuthLayout.SideImage)
            {
                <div class="hidden bg-cover lg:block lg:w-2/3" style="background-image: url(@(string.IsNullOrEmpty(Block.BackgroundImageUrl) ? "https://images.unsplash.com/photo-1616763355603-9755a640a287?ixlib=rb-1.2.1&auto=format&fit=crop&w=1470&q=80" : Block.BackgroundImageUrl))">
                    <div class="flex items-center h-full px-20 bg-gray-900 bg-opacity-40">
                        <div>
                            <h2 class="text-4xl font-bold text-white">@Block.Title</h2>
                            <p class="max-w-xl mt-3 text-gray-300">@Block.Description</p>
                        </div>
                    </div>
                </div>
            }

            <div class="flex items-center w-full max-w-md px-6 mx-auto @(Block.Layout == AeroAuthLayout.SideImage ? "lg:w-2/6" : "lg:w-full")">
                <div class="flex-1">
                    <div class="text-center">
                        <h2 class="text-4xl font-bold text-center text-gray-700 dark:text-white">@Block.Title</h2>
                        <p class="mt-3 text-gray-500 dark:text-gray-300">@Block.Description</p>
                    </div>

                    <div class="mt-8">
                        <div class="space-y-4">
                            <div>
                                <label for="email" class="block mb-2 text-sm text-gray-600 dark:text-gray-200">Email Address</label>
                                <input type="email" name="email" id="email" placeholder="example@example.com" class="block w-full px-4 py-2 mt-2 text-gray-700 placeholder-gray-400 bg-white border border-gray-200 rounded-md dark:placeholder-gray-600 dark:bg-gray-900 dark:text-gray-300 dark:border-gray-700 focus:border-blue-400 dark:focus:border-blue-400 focus:ring-blue-400 focus:outline-none focus:ring focus:ring-opacity-40" />
                            </div>

                            <div class="mt-6">
                                <div class="flex justify-between mb-2">
                                    <label for="password" class="text-sm text-gray-600 dark:text-gray-200">Password</label>
                                </div>
                                <input type="password" name="password" id="password" placeholder="Your Password" class="block w-full px-4 py-2 mt-2 text-gray-700 placeholder-gray-400 bg-white border border-gray-200 rounded-md dark:placeholder-gray-600 dark:bg-gray-900 dark:text-gray-300 dark:border-gray-700 focus:border-blue-400 dark:focus:border-blue-400 focus:ring-blue-400 focus:outline-none focus:ring focus:ring-opacity-40" />
                            </div>

                            <div class="mt-6">
                                <button class="w-full px-4 py-2 tracking-wide text-white transition-colors duration-300 transform bg-blue-500 rounded-md hover:bg-blue-400 focus:outline-none focus:bg-blue-400 focus:ring focus:ring-blue-300 focus:ring-opacity-50">
                                    @Block.SubmitButtonText
                                </button>
                            </div>
                        </div>

                        <p class="mt-6 text-sm text-center text-gray-400">@Block.AlternativeLinkText <a href="@Block.AlternativeLinkUrl" class="text-blue-500 focus:outline-none focus:underline hover:underline">Click here</a>.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public AeroAuthBlock? Block { get; set; }
}
