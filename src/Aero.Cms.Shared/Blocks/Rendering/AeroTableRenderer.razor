@using Aero.Cms.Core.Blocks.Common
@using Aero.Cms.Core.Blocks

@if (Block != null)
{
    <section class="container px-4 mx-auto py-12">
        <h2 class="text-2xl font-medium text-gray-800 dark:text-white">@Block.Title</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-300">@Block.Description</p>

        <div class="flex flex-col mt-6">
            <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
                    <div class="overflow-hidden border border-gray-200 dark:border-gray-700 md:rounded-lg">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                            <thead class="bg-gray-50 dark:bg-gray-800">
                                <tr>
                                    @foreach (var header in Block.Headers)
                                    {
                                        <th scope="col" class="py-3.5 px-4 text-sm font-normal text-left rtl:text-right text-gray-500 dark:text-gray-400">
                                            @header.Label
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200 dark:divide-gray-700 dark:bg-gray-900">
                                @foreach (var row in Block.Rows)
                                {
                                    <tr>
                                        @foreach (var cell in row.Cells)
                                        {
                                            <td class="px-4 py-4 text-sm font-medium whitespace-nowrap text-gray-800 dark:text-white">
                                                @cell
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public AeroTableBlock? Block { get; set; }
}
