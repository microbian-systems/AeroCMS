@using Aero.Cms.Abstractions.Blocks.Layout
@if (Column != null)
{
    <div class="@GetSpanClass(Column.Width)">
        @foreach (var block in Column.Blocks.OrderBy(b => b.Order))
        {
            <BlockPlacementRenderer Placement="block" />
        }
    </div>
}

@code {
    [Parameter]
    public LayoutColumn? Column { get; set; }

    private string GetSpanClass(int width)
    {
        return width switch
        {
            1 => "col-span-1",
            2 => "col-span-2",
            3 => "col-span-3",
            4 => "col-span-4",
            5 => "col-span-5",
            6 => "col-span-6",
            7 => "col-span-7",
            8 => "col-span-8",
            9 => "col-span-9",
            10 => "col-span-10",
            11 => "col-span-11",
            12 => "col-span-12",
            _ => "col-span-12"
        };
    }
}
