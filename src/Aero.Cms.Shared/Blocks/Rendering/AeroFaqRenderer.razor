@using Aero.Cms.Core.Blocks.Common
@using Aero.Cms.Core.Blocks

@if (Block != null)
{
    <section class="bg-white dark:bg-gray-900">
        <div class="container px-6 py-12 mx-auto">
            <h1 class="text-2xl font-semibold text-gray-800 lg:text-3xl dark:text-white">@Block.Title</h1>
            @if (!string.IsNullOrEmpty(Block.Description))
            {
                <p class="mt-4 text-gray-500 dark:text-gray-300">@Block.Description</p>
            }

            <div class="mt-8 space-y-8 lg:mt-12">
                @foreach (var item in Block.Items)
                {
                    <div class="p-8 bg-gray-100 rounded-lg dark:bg-gray-800">
                        <button class="flex items-center justify-between w-full">
                            <h1 class="font-semibold text-gray-700 dark:text-white">@item.Question</h1>
                            <span class="text-gray-400 bg-gray-200 rounded-full dark:bg-gray-700">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6" />
                                </svg>
                            </span>
                        </button>
                        <p class="mt-6 text-sm text-gray-500 dark:text-gray-300">@item.Answer</p>
                    </div>
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public AeroFaqBlock? Block { get; set; }
}
