@using Aero.Cms.Abstractions.Blocks.Common
@using Aero.Cms.Core.Blocks

@if (Block != null)
{
    <section class="bg-white dark:bg-gray-900">
        <div class="container px-6 py-10 mx-auto">
            <div class="text-center">
                <h1 class="text-3xl font-semibold text-gray-800 capitalize lg:text-4xl dark:text-white">@Block.Title</h1>

                <p class="max-w-lg mx-auto mt-4 text-gray-500">
                    @Block.Description
                </p>
            </div>

            <div class="grid grid-cols-1 gap-8 mt-8 lg:grid-cols-2">
                @if (Block.Posts != null)
                {
                    @foreach (var post in Block.Posts)
                    {
                        <div>
                            <img class="relative z-10 object-cover w-full rounded-md h-96" src="@(string.IsNullOrEmpty(post.ImageUrl) ? "https://images.unsplash.com/photo-1644018335954-ab54c83e007f?ixlib=rb-1.2.1&auto=format&fit=crop&w=1470&q=80" : post.ImageUrl)" alt="">

                            <div class="relative z-20 max-w-lg p-6 mx-auto -mt-20 bg-white rounded-md shadow dark:bg-gray-900">
                                <a href="@post.PostUrl" class="font-semibold text-gray-800 hover:underline dark:text-white md:text-xl">
                                    @post.Title
                                </a>

                                <p class="mt-3 text-sm text-gray-500 dark:text-gray-300 md:text-sm">
                                    @post.Description
                                </p>

                                <div class="flex items-center mt-3 space-x-2">
                                    <p class="text-sm text-blue-500">@post.PublishedAt</p>
                                    @if (!string.IsNullOrEmpty(post.Category))
                                    {
                                        <span class="text-sm text-gray-300">|</span>
                                        <p class="text-sm text-gray-500">@post.Category</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter]
    public AeroBlogBlock? Block { get; set; }
}
