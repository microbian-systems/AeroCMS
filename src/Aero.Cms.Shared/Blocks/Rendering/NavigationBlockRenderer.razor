@using Aero.Cms.Core.Blocks
@using Aero.Cms.Core.Http.Clients

@if (Block != null && navigation != null)
{
    <nav class="navigation-block my-6">
        @if (!string.IsNullOrEmpty(Block.Title))
        {
            <h3 class="text-lg font-semibold mb-4 text-gray-900">@Block.Title</h3>
        }
        <ul class="flex flex-col gap-2">
            @foreach (var item in navigation.Items.OrderBy(i => i.Order))
            {
                <li>
                    <a href="@item.Url" class="text-blue-600 hover:text-blue-800 hover:underline transition-colors">
                        @item.Label
                    </a>
                </li>
            }
        </ul>
    </nav>
}
else if (Block != null && isLoading)
{
    <div class="animate-pulse flex space-x-4 my-6">
        <div class="flex-1 space-y-4 py-1">
            <div class="h-4 bg-gray-200 rounded w-3/4"></div>
            <div class="space-y-2">
                <div class="h-4 bg-gray-200 rounded"></div>
                <div class="h-4 bg-gray-200 rounded w-5/6"></div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public NavigationBlock? Block { get; set; }

    private NavigationDetail? navigation;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        if (Block != null && Block.NavigationId > 0)
        {
            isLoading = true;
            try 
            {
                navigation = await NavClient.GetByIdAsync(Block.NavigationId);
            }
            finally 
            {
                isLoading = false;
            }
        }
    }
}
