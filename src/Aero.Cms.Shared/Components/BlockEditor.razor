@using Aero.Cms.Core.Blocks
@using Aero.Cms.Core.Http.Clients
@inject BlockEditingService BlockService
@inject NavigationsHttpClient NavClient

<div class="block-editor">
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white">
                <RadzenIcon Icon="@GetBlockIcon()" Style="font-size: 1.25rem;" />
            </div>
            <div>
                <RadzenText TextStyle="TextStyle.H6" Class="rz-mb-0">
                    Edit @GetBlockDisplayName()
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Caption" Class="rz-text-secondary">
                    Block #@(Block?.Order + 1 ?? 0)
                </RadzenText>
            </div>
        </div>
        <div class="flex gap-2">
            <RadzenButton Click="MoveUp"
                          Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Light"
                          Icon="arrow_upward"
                          Size="ButtonSize.Small"
                          Disabled="!CanMoveUp"
                          Title="Move up" />
            <RadzenButton Click="MoveDown"
                          Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Light"
                          Icon="arrow_downward"
                          Size="ButtonSize.Small"
                          Disabled="!CanMoveDown"
                          Title="Move down" />
            <RadzenButton Click="DuplicateBlock"
                          Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Light"
                          Icon="content_copy"
                          Size="ButtonSize.Small"
                          Title="Duplicate" />
            <RadzenButton Click="DeleteBlock"
                          Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Danger"
                          Icon="delete"
                          Size="ButtonSize.Small"
                          Title="Delete" />
        </div>
    </div>

    @if (Block is not null)
    {
        <div class="space-y-6">
            @switch (Block)
            {
                case RichTextBlock richText:
                    <div class="form-group">
                        <RadzenLabel Text="Content" Component="richTextContent" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenHtmlEditor @bind-Value="richText.Content"
                                         id="richTextContent"
                                         Style="height: 300px;"
                                         Class="w-full" />
                        <RadzenText TextStyle="TextStyle.Caption" Class="rz-text-secondary mt-1">
                            Enter the rich text content for this block
                        </RadzenText>
                    </div>
                    break;

                case HeadingBlock heading:
                    <div class="form-group">
                        <RadzenLabel Text="Heading Level" Component="headingLevel" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenDropDown @bind-Value="heading.Level"
                                       Data="HeadingLevels"
                                       TextProperty="Text"
                                       ValueProperty="Value"
                                       id="headingLevel"
                                       Class="w-full" />
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Text" Component="headingText" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="heading.Text"
                                      id="headingText"
                                      Placeholder="Enter heading text..."
                                      Class="w-full" />
                        @if (ShowValidationErrors && string.IsNullOrWhiteSpace(heading.Text))
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Class="text-red-500 mt-1">
                                <RadzenIcon Icon="error" Class="rz-mr-1" Style="font-size: 0.875rem;" />
                                Heading text is required
                            </RadzenText>
                        }
                    </div>
                    break;

                case ImageBlock image:
                    <div class="form-group">
                        <RadzenLabel Text="Media" Component="mediaSelector" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <div class="flex items-center gap-3 p-4 border-2 border-dashed border-gray-300 rounded-lg hover:border-blue-400 transition-colors">
                            @if (image.MediaId > 0)
                            {
                                <div class="w-16 h-16 bg-gray-100 rounded-lg flex items-center justify-center">
                                    <RadzenIcon Icon="image" Class="text-gray-400" Style="font-size: 2rem;" />
                                </div>
                                <div class="flex-1">
                                    <p class="text-sm font-medium text-gray-900">Media ID: @image.MediaId</p>
                                    <p class="text-xs text-gray-500">Selected media asset</p>
                                </div>
                            }
                            else
                            {
                                <div class="w-16 h-16 bg-gray-50 rounded-lg flex items-center justify-center">
                                    <RadzenIcon Icon="add_photo_alternate" Class="text-gray-400" Style="font-size: 2rem;" />
                                </div>
                                <div class="flex-1">
                                    <p class="text-sm font-medium text-gray-900">No image selected</p>
                                    <p class="text-xs text-gray-500">Click to select from media library</p>
                                </div>
                            }
                            <RadzenButton Text="Select Media"
                                         Variant="Variant.Outlined"
                                         Size="ButtonSize.Small"
                                         Click="SelectMedia" />
                        </div>
                        @if (ShowValidationErrors && image.MediaId <= 0)
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Class="text-red-500 mt-1">
                                <RadzenIcon Icon="error" Class="rz-mr-1" Style="font-size: 0.875rem;" />
                                Please select an image
                            </RadzenText>
                        }
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Alternative Text" Component="altText" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="image.AltText"
                                      id="altText"
                                      Placeholder="Describe the image for accessibility..."
                                      Class="w-full" />
                        <RadzenText TextStyle="TextStyle.Caption" Class="rz-text-secondary mt-1">
                            Used by screen readers and when image cannot load
                        </RadzenText>
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Caption" Component="caption" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextArea @bind-Value="image.Caption"
                                       id="caption"
                                       Placeholder="Optional caption text..."
                                       Rows="2"
                                       Class="w-full" />
                    </div>
                    break;

                case CtaBlock cta:
                    <div class="form-group">
                        <RadzenLabel Text="Button Text" Component="ctaText" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="cta.Text"
                                      id="ctaText"
                                      Placeholder="e.g., Learn More, Get Started..."
                                      Class="w-full" />
                        @if (ShowValidationErrors && string.IsNullOrWhiteSpace(cta.Text))
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Class="text-red-500 mt-1">
                                <RadzenIcon Icon="error" Class="rz-mr-1" Style="font-size: 0.875rem;" />
                                Button text is required
                            </RadzenText>
                        }
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="URL" Component="ctaUrl" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="cta.Url"
                                      id="ctaUrl"
                                      Placeholder="https://example.com or /page/path"
                                      Class="w-full" />
                        @if (ShowValidationErrors && string.IsNullOrWhiteSpace(cta.Url))
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Class="text-red-500 mt-1">
                                <RadzenIcon Icon="error" Class="rz-mr-1" Style="font-size: 0.875rem;" />
                                URL is required
                            </RadzenText>
                        }
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Style Class (Optional)" Component="ctaStyle" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="cta.Style"
                                      id="ctaStyle"
                                      Placeholder="e.g., btn-primary, btn-large..."
                                      Class="w-full" />
                        <RadzenText TextStyle="TextStyle.Caption" Class="rz-text-secondary mt-1">
                            Custom CSS class for styling the button
                        </RadzenText>
                    </div>
                    break;

                case QuoteBlock quote:
                    <div class="form-group">
                        <RadzenLabel Text="Quote Content" Component="quoteContent" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextArea @bind-Value="quote.Content"
                                       id="quoteContent"
                                       Placeholder="Enter the quote text..."
                                       Rows="4"
                                       Class="w-full" />
                        @if (ShowValidationErrors && string.IsNullOrWhiteSpace(quote.Content))
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Class="text-red-500 mt-1">
                                <RadzenIcon Icon="error" Class="rz-mr-1" Style="font-size: 0.875rem;" />
                                Quote content is required
                            </RadzenText>
                        }
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Author (Optional)" Component="quoteAuthor" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="quote.Author"
                                      id="quoteAuthor"
                                      Placeholder="e.g., Albert Einstein..."
                                      Class="w-full" />
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Source/Citation (Optional)" Component="quoteCitation" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="quote.Citation"
                                      id="quoteCitation"
                                      Placeholder="e.g., The Theory of Relativity, 1915..."
                                      Class="w-full" />
                    </div>
                    break;

                case EmbedBlock embed:
                    <div class="form-group">
                        <RadzenLabel Text="Embed Type" Component="embedType" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenDropDown @bind-Value="embed.EmbedType"
                                       Data="EmbedTypes"
                                       Placeholder="Select embed type..."
                                       id="embedType"
                                       Class="w-full" />
                        @if (ShowValidationErrors && string.IsNullOrWhiteSpace(embed.EmbedType))
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Class="text-red-500 mt-1">
                                <RadzenIcon Icon="error" Class="rz-mr-1" Style="font-size: 0.875rem;" />
                                Embed type is required
                            </RadzenText>
                        }
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Source URL" Component="sourceUrl" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="embed.SourceUrl"
                                      id="sourceUrl"
                                      Placeholder="https://youtube.com/watch?v=..."
                                      Class="w-full" />
                        @if (ShowValidationErrors && string.IsNullOrWhiteSpace(embed.SourceUrl))
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Class="text-red-500 mt-1">
                                <RadzenIcon Icon="error" Class="rz-mr-1" Style="font-size: 0.875rem;" />
                                Source URL is required
                            </RadzenText>
                        }
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Thumbnail URL (Optional)" Component="thumbnailUrl" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="embed.ThumbnailUrl"
                                      id="thumbnailUrl"
                                      Placeholder="https://example.com/thumbnail.jpg"
                                      Class="w-full" />
                    </div>
                    break;

                case NavigationBlock nav:
                    <div class="form-group">
                        <RadzenLabel Text="Title (Optional)" Component="navTitle" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenTextBox @bind-Value="nav.Title"
                                      id="navTitle"
                                      Placeholder="e.g., Quick Links, Resources..."
                                      Class="w-full" />
                    </div>
                    <div class="form-group mt-4">
                        <RadzenLabel Text="Navigation Menu" Component="navMenu" Class="block text-sm font-medium text-gray-700 mb-2" />
                        <RadzenDropDown @bind-Value="nav.NavigationId"
                                       Data="AvailableNavigations"
                                       TextProperty="Name"
                                       ValueProperty="Id"
                                       Placeholder="Select a navigation menu..."
                                       id="navMenu"
                                       Class="w-full" />
                        @if (ShowValidationErrors && nav.NavigationId <= 0)
                        {
                            <RadzenText TextStyle="TextStyle.Caption" Class="text-red-500 mt-1">
                                <RadzenIcon Icon="error" Class="rz-mr-1" Style="font-size: 0.875rem;" />
                                Please select a navigation menu
                            </RadzenText>
                        }
                    </div>
                    break;

                default:
                    <div class="p-8 text-center text-gray-500">
                        <RadzenIcon Icon="block" Style="font-size: 3rem; margin-bottom: 1rem;" />
                        <p>Unknown block type: @(Block?.GetType().Name ?? "null")</p>
                    </div>
                    break;
            }
        </div>

        <div class="mt-6 pt-6 border-t border-gray-200 flex justify-end gap-3">
            <RadzenButton Click="CancelEdit"
                         Variant="Variant.Outlined"
                         Text="Cancel"
                         Class="px-4" />
            <RadzenButton Click="SaveBlock"
                         Variant="Variant.Filled"
                         ButtonStyle="ButtonStyle.Primary"
                         Text="Save Changes"
                         Icon="save"
                         Class="px-4" />
        </div>
    }
    else
    {
        <div class="p-8 text-center text-gray-500">
            <RadzenIcon Icon="edit_note" Style="font-size: 3rem; margin-bottom: 1rem;" />
            <p>No block selected for editing</p>
        </div>
    }
</div>

@code {
    /// <summary>
    /// The block to edit.
    /// </summary>
    [Parameter]
    public BlockBase? Block { get; set; }

    /// <summary>
    /// Event callback fired when the block is saved.
    /// </summary>
    [Parameter]
    public EventCallback<BlockBase> OnSave { get; set; }

    /// <summary>
    /// Event callback fired when editing is cancelled.
    /// </summary>
    [Parameter]
    public EventCallback OnCancel { get; set; }

    /// <summary>
    /// Event callback fired when the block should be deleted.
    /// </summary>
    [Parameter]
    public EventCallback<BlockBase> OnDelete { get; set; }

    /// <summary>
    /// Event callback fired when the block should be duplicated.
    /// </summary>
    [Parameter]
    public EventCallback<BlockBase> OnDuplicate { get; set; }

    /// <summary>
    /// Event callback fired when the block should move up.
    /// </summary>
    [Parameter]
    public EventCallback<BlockBase> OnMoveUp { get; set; }

    /// <summary>
    /// Event callback fired when the block should move down.
    /// </summary>
    [Parameter]
    public EventCallback<BlockBase> OnMoveDown { get; set; }

    /// <summary>
    /// Indicates whether the block can be moved up.
    /// </summary>
    [Parameter]
    public bool CanMoveUp { get; set; } = true;

    /// <summary>
    /// Indicates whether the block can be moved down.
    /// </summary>
    [Parameter]
    public bool CanMoveDown { get; set; } = true;

    private bool ShowValidationErrors { get; set; }
    private IReadOnlyList<NavigationSummary> AvailableNavigations { get; set; } = Array.Empty<NavigationSummary>();

    protected override async Task OnInitializedAsync()
    {
        var result = await NavClient.GetAllAsync();
        if (result is Result<string, IReadOnlyList<NavigationSummary>>.Ok ok && ok.Value != null)
        {
            AvailableNavigations = ok.Value;
        }
    }

    private readonly List<dynamic> HeadingLevels = new()
    {
        new { Value = 1, Text = "H1 - Main Title" },
        new { Value = 2, Text = "H2 - Section Heading" },
        new { Value = 3, Text = "H3 - Subsection" },
        new { Value = 4, Text = "H4 - Minor Heading" },
        new { Value = 5, Text = "H5 - Small Heading" },
        new { Value = 6, Text = "H6 - Smallest Heading" }
    };

    private readonly List<string> EmbedTypes = new()
    {
        "youtube",
        "vimeo",
        "twitter",
        "instagram",
        "spotify",
        "codepen",
        "codesandbox",
        "other"
    };

    private async Task SaveBlock()
    {
        ShowValidationErrors = true;

        if (Block is null)
        {
            return;
        }

        var validationResult = BlockService.ValidateBlock(Block);
        if (validationResult is Result<string[], bool>.Ok)
        {
            await OnSave.InvokeAsync(Block);
            ShowValidationErrors = false;
        }
    }

    private async Task CancelEdit()
    {
        ShowValidationErrors = false;
        await OnCancel.InvokeAsync();
    }

    private async Task DeleteBlock()
    {
        if (Block is not null)
        {
            await OnDelete.InvokeAsync(Block);
        }
    }

    private async Task DuplicateBlock()
    {
        if (Block is not null)
        {
            await OnDuplicate.InvokeAsync(Block);
        }
    }

    private async Task MoveUp()
    {
        if (Block is not null)
        {
            await OnMoveUp.InvokeAsync(Block);
        }
    }

    private async Task MoveDown()
    {
        if (Block is not null)
        {
            await OnMoveDown.InvokeAsync(Block);
        }
    }

    private void SelectMedia()
    {
        // This would open a media picker dialog
        // For now, just a placeholder
    }

    private string GetBlockIcon() => Block?.BlockType?.ToLowerInvariant() switch
    {
        "rich_text" => "text_fields",
        "heading" => "title",
        "image" => "image",
        "cta" => "touch_app",
        "quote" => "format_quote",
        "embed" => "code",
        "navigation" => "nav_menu",
        _ => "widgets"
    };

    private string GetBlockDisplayName() => Block?.BlockType?.ToLowerInvariant() switch
    {
        "rich_text" => "Rich Text",
        "heading" => "Heading",
        "image" => "Image",
        "cta" => "Call to Action",
        "quote" => "Quote",
        "embed" => "Embed",
        "navigation" => "Navigation Menu",
        _ => "Block"
    };
}