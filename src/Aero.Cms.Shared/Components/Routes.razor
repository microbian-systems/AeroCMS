@using Aero.Cms.Shared.Services
@using Aero.Cms.Shared.Layout
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager NavigationManager
@inject IFormFactor FormFactor

<Router AppAssembly="@typeof(Routes).Assembly" AdditionalAssemblies="new[] { typeof(Aero.Cms.Shared._Imports).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(DarkModeLayout)" />
    </Found>
    <NotFound>
        @if (FormFactor.GetFormFactor() != "Web")
        {
            @* Directly perform the redirect for the MAUI client to start at the manager *@
           NavigationManager.NavigateTo("/manager"); 
        }
        else
        {
            <LayoutView Layout="@typeof(Aero.Cms.Shared.Layout.MainLayout)">
                <p>Sorry, there's nothing at this address.</p>
            </LayoutView>
        }
    </NotFound>
</Router>

@code {
    protected override void OnInitialized()
    {
        // On MAUI (non-web), the app starts at / by default.
        // We want to redirect those clients automatically to the manager startup page.
        // This prevents shadowing the Web application's actual home page at /.
        if (FormFactor.GetFormFactor() != "Web" && IsAtRoot())
        {
            NavigationManager.NavigateTo("/manager/start", true);
        }
    }

    private bool IsAtRoot()
    {
        var uri = NavigationManager.Uri.TrimEnd('/');
        var baseUri = NavigationManager.BaseUri.TrimEnd('/');
        return string.Equals(uri, baseUri, StringComparison.OrdinalIgnoreCase);
    }
}
