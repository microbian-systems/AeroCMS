@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Navigation

<div class="pe-nav-section">
    <div class="pe-nav-section-header">
        <NavLink class="pe-nav-link" href="@Href" Match="@Match">
            <div class="pe-nav-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@Icon" />
                </svg>
            </div>
            @if (!IsCollapsed)
            {
                <span>@Label</span>
            }
        </NavLink>
        
        @if (!IsCollapsed && ChildContent != null)
        {
            <button @onclick="ToggleExpand" @onclick:stopPropagation="true" class="pe-nav-expand-btn @(isExpanded ? "rotated" : "")">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
        }
    </div>

    @if (isExpanded && !IsCollapsed && ChildContent != null)
    {
        <div class="pe-nav-sub">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Href { get; set; } = "";
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Expanded { get; set; }
    [Parameter] public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;

    private bool isExpanded;

    protected override void OnInitialized()
    {
        isExpanded = Expanded;
        // If the current URL starts with Href, expand it
        if (!string.IsNullOrEmpty(Href) && Navigation.Uri.Contains(Href))
        {
            isExpanded = true;
        }
    }

    private void ToggleExpand()
    {
        isExpanded = !isExpanded;
    }
}
