@inherits LayoutComponentBase
@using Aero.Cms.Shared.Services
@using Aero.Cms.Shared.Layout
@using Microsoft.AspNetCore.Components.Sections
@inject ManagerThemeService ThemeService
@inject NavigationManager Navigation
@implements IDisposable

<div class="pe-root" data-theme="@ThemeService.Theme">
    <ManagerHeader />
    
    <div class="pe-main-layout">
        <AeroSidebar Title="Menu" 
                     Side="SidebarSide.Left" 
                     IsCollapsed="@ThemeService.IsSidebarCollapsed"
                     IsCollapsedChanged="@(async (c) => ThemeService.ToggleSidebar())">
            <NavMenu IsCollapsed="@ThemeService.IsSidebarCollapsed" />
        </AeroSidebar>

        <div class="pe-editor-area">
            @Body
        </div>

        <SectionOutlet SectionName="RightSidebar" />
    </div>
</div>

<RadzenComponents />

@code {
    private string? redirectTarget;

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (relative.StartsWith("manager/login", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        redirectTarget = string.IsNullOrWhiteSpace(relative) || relative.Equals("manager", StringComparison.OrdinalIgnoreCase)
            ? "/manager/login?returnUrl=%2Fmanager"
            : $"/manager/login?returnUrl={Uri.EscapeDataString("/" + relative)}";
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrWhiteSpace(redirectTarget))
        {
            Navigation.NavigateTo(redirectTarget, forceLoad: true);
        }

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}
