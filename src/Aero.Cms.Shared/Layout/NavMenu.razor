@using Aero.Cms.Core.Http.Clients
@using Aero.Core.Railway
@inject DocsClient DocsClient
@inject NotificationService NotificationService

<aside class="@NavMenuCssClass bg-white border-r border-gray-200 transition-all duration-300 flex flex-col z-20">
    <div class="h-16 flex items-center justify-between px-4 border-b border-gray-100 flex-shrink-0">
        <div class="flex items-center space-x-3 overflow-hidden">
            <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
            </div>
            @if (!collapseNavMenu)
            {
                <span class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-violet-600 truncate">Aero CMS</span>
            }
        </div>
        <button @onclick="ToggleNavMenu" class="p-1 hover:bg-gray-100 rounded-md transition-colors text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5 transform @(collapseNavMenu ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
            </svg>
        </button>
    </div>

    <div class="flex-1 overflow-y-auto py-4 scrollbar-hide">
        <nav class="space-y-1 px-3">
            @* 0. Dashboard *@
            <NavMenuSection Href="/manager" Label="Dashboard" Icon="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" IsCollapsed="collapseNavMenu" Match="NavLinkMatch.All">
                <NavMenuItem Href="/manager/settings" Label="Settings" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 1. Navigations *@
            <NavMenuSection Href="/manager/navigations" Label="Navigations" Icon="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/navigations/general" Label="General" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 2. Posts *@
            <NavMenuSection Href="/manager/posts" Label="Posts" Icon="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/posts/general" Label="General" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 3. Pages *@
            <NavMenuSection Href="/manager/pages" Label="Pages" Icon="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/pages/general" Label="General" IsCollapsed="collapseNavMenu"/>
                <NavMenuItem Href="/manager/page/editor/0" Label="New Page" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 4. Docs *@
            <NavMenuSection Href="/manager/docs" Label="Docs" Icon="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/docs/general" Label="General" IsCollapsed="collapseNavMenu"/>
                @if (docsCategories != null)
                {
                    @foreach (var category in docsCategories)
                    {
                        <NavMenuItem Href="@($"/manager/docs/categories/{category.Slug}")" Label="@category.Title" IsCollapsed="collapseNavMenu"/>
                    }
                }
            </NavMenuSection>

            <NavMenuSection Href="/manager/HotReload" Label="Modules" Icon="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/HotReload/general" Label="Hot 🔥" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 5. Modules *@
            <NavMenuSection Href="/manager/modules" Label="Modules" Icon="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/modules/general" Label="General" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 6. Databases *@
            <NavMenuSection Href="/manager/databases" Label="Databases" Icon="M4 7v10c0 2.21 4.48 4 10 4s10-1.79 10-4V7M4 7c0 2.21 4.48 4 10 4s10-1.79 10-4M4 7c0-2.21 4.48-4 10-4s10 1.79 10 4m0 5c0 2.21-4.48 4-10 4s-10-1.79-10-4" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/databases/general" Label="General" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 7. Taxonomy Group *@
            <NavMenuSection Label="Taxonomy" Icon="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/taxonomy/general" Label="General" IsCollapsed="collapseNavMenu"/>
                <NavMenuItem Href="/manager/taxonomy/categories" Label="Categories" IsCollapsed="collapseNavMenu"/>
                <NavMenuItem Href="/manager/taxonomy/tags" Label="Tags" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 8. Media *@
            <NavMenuSection Href="/manager/media" Label="Media" Icon="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/media/general" Label="General" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 9. Users *@
            <NavMenuSection Href="/manager/users" Label="Users" Icon="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/users/general" Label="General" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 10. Themes *@
            <NavMenuSection Href="/manager/themes" Label="Themes" Icon="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/themes/general" Label="General" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>

            @* 11. SEO *@
            <NavMenuSection Href="/manager/seo" Label="SEO" Icon="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" IsCollapsed="collapseNavMenu">
                <NavMenuItem Href="/manager/seo/general" Label="General" IsCollapsed="collapseNavMenu"/>
            </NavMenuSection>
        </nav>
    </div>

    @* 12. Settings - Moved out of the main loop loop for now or kept as is *@
    <div class="p-4 border-t border-gray-100 flex-shrink-0">
        <NavMenuItem Href="/manager/settings" Icon="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" Label="Settings" IsCollapsed="collapseNavMenu"/>
    </div>
</aside>

@code {
    private bool collapseNavMenu = false;
    private string? NavMenuCssClass => collapseNavMenu ? "w-20" : "w-64";
    private IReadOnlyList<DocsSummary>? docsCategories;

    protected override async Task OnInitializedAsync()
    {
        var result = await DocsClient.GetCategoriesAsync();

        if (result is Result<string, IReadOnlyList<DocsSummary>>.Ok ok)
        {
            docsCategories = ok.Value;
        }
        else if (result is Result<string, IReadOnlyList<DocsSummary>>.Failure failure)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Error Loading Docs",
                Detail = failure.Error,
                Duration = 4000
            });
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

}