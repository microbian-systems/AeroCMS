<NavLink class="flex items-center space-x-3 px-3 py-2 rounded-lg transition-all duration-200 group hover:bg-indigo-50 active:bg-indigo-100" href="@Href" Match="@Match">
    <div class="flex-shrink-0 w-6 h-6 flex items-center justify-center">
        <svg class="w-5 h-5 text-gray-400 group-hover:text-indigo-600 group-[.active]:text-indigo-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@Icon" />
        </svg>
    </div>
    @if (!IsCollapsed)
    {
        <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900 group-[.active]:text-gray-900 transition-colors truncate">@Label</span>
    }
</NavLink>

<style>
    .group.active {
        @@apply bg-indigo-50;
    }
</style>

@code {
    [Parameter] public string Href { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;
}
