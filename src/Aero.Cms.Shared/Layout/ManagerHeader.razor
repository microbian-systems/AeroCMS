@using Aero.Cms.Shared.Services
@inject ManagerThemeService Theme
@inject HttpClient Http
@inject NavigationManager Navigation

<header class="pe-header">
    <div class="pe-header-left">
        <a href="/manager" class="pe-logo">
            <div class="pe-logo-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
            </div>
            <span class="pe-logo-text">AERO</span>
        </a>

        <nav class="pe-nav">
            <NavLink class="pe-nav-link" href="/manager" Match="NavLinkMatch.All">Dashboard</NavLink>
            <NavLink class="pe-nav-link" href="/manager/pages">Pages</NavLink>
            <NavLink class="pe-nav-link" href="/manager/posts">Posts</NavLink>
            <NavLink class="pe-nav-link" href="/manager/media">Media</NavLink>
            <NavLink class="pe-nav-link" href="/manager/navigations">Navigations</NavLink>
            <NavLink class="pe-nav-link" href="/manager/docs">Docs</NavLink>
            <NavLink class="pe-nav-link" href="/manager/modules">Modules</NavLink>
            <NavLink class="pe-nav-link" href="/manager/taxonomy/general">Taxonomy</NavLink>
            <NavLink class="pe-nav-link" href="/manager/users">Users</NavLink>
            <NavLink class="pe-nav-link" href="/manager/seo">SEO</NavLink>
            <NavLink class="pe-nav-link" href="/manager/settings">Settings</NavLink>
        </nav>
    </div>

    <div class="pe-header-right">
        <button class="pe-btn pe-btn-ghost pe-btn-sm" @onclick="Theme.ToggleThemeAsync" title="Toggle Light/Dark Mode">
            @if (Theme.IsDarkMode)
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"></circle>
                    <line x1="12" y1="1" x2="12" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="23"></line>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                    <line x1="1" y1="12" x2="3" y2="12"></line>
                    <line x1="21" y1="12" x2="23" y2="12"></line>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                </svg>
            }
            else
            {
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            }
        </button>
        
        <div class="pe-user-profile">
            <button class="pe-btn pe-btn-ghost pe-btn-sm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                <span>Account</span>
            </button>
            <button class="pe-btn pe-btn-ghost pe-btn-sm" @onclick="LogoutAsync">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                <span>Logout</span>
            </button>
        </div>
    </div>
</header>

@code {
    private async Task LogoutAsync()
    {
        try
        {
            await Http.PostAsync("api/v1/admin/auth/logout", content: null);
        }
        finally
        {
            Navigation.NavigateTo("/manager/login", forceLoad: true);
        }
    }
}
