@inherits LayoutComponentBase

<style>
    /* ── CSS Variables ──────────────────────────────────────── */
    .pe-root {
        --pe-primary:        #6366f1;
        --pe-primary-dark:   #4f46e5;
        --pe-primary-light:  #818cf8;
        --pe-secondary:      #64748b;
        --pe-success:        #22c55e;
        --pe-error:          #ef4444;
        --pe-warning:        #f59e0b;
        --pe-info:           #3b82f6;

        --pe-bg-primary:     #0f172a;
        --pe-bg-secondary:   #1e293b;
        --pe-bg-tertiary:    #334155;
        --pe-bg-hover:       #475569;

        --pe-text-primary:   #f8fafc;
        --pe-text-secondary: #cbd5e1;
        --pe-text-muted:     #94a3b8;

        --pe-border:         #334155;
        --pe-border-light:   #475569;

        --pe-radius-sm:      6px;
        --pe-radius-md:      8px;
        --pe-radius-lg:      12px;

        --pe-shadow-sm:      0 1px 2px rgba(0,0,0,.3);
        --pe-shadow-md:      0 4px 6px rgba(0,0,0,.4);
        --pe-shadow-lg:      0 10px 15px rgba(0,0,0,.5);

        --pe-header-h:       60px;
        --pe-sidebar-w:      260px;
        --pe-sidebar-coll:   60px;

        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: var(--pe-text-primary);
        overflow: hidden;
    }

    /* ── Full-screen shell ──────────────────────────────────── */
    .pe-root {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: var(--pe-bg-primary);
    }

    /* ── Header ─────────────────────────────────────────────── */
    .pe-header {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: var(--pe-header-h);
        background: var(--pe-bg-secondary);
        border-bottom: 1px solid var(--pe-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 1000;
        flex-shrink: 0;
    }

    .pe-header-left  { display: flex; align-items: center; gap: 32px; }
    .pe-header-right { display: flex; align-items: center; gap: 8px; }

    .pe-logo { display: flex; align-items: center; gap: 10px; }
    .pe-logo-text { font-size: 20px; font-weight: 700; color: var(--pe-text-primary); }

    .pe-nav { display: flex; gap: 4px; }
    .pe-nav-link {
        padding: 8px 16px;
        color: var(--pe-text-secondary);
        text-decoration: none;
        font-size: 14px; font-weight: 500;
        border-radius: var(--pe-radius-md);
        transition: all .2s;
        cursor: pointer; background: transparent; border: none;
    }
    .pe-nav-link:hover { color: var(--pe-text-primary); background: var(--pe-bg-tertiary); }
    .pe-nav-link.active { color: var(--pe-primary-light); background: rgba(99,102,241,.1); }

    /* ── Shared button styles ───────────────────────────────── */
    .pe-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 16px; font-size: 14px; font-weight: 500;
        border: none; border-radius: var(--pe-radius-md);
        cursor: pointer; transition: all .2s; font-family: inherit;
    }
    .pe-btn-sm  { padding: 6px 12px; font-size: 12px; }
    .pe-btn-primary   { background: var(--pe-primary); color: #fff; }
    .pe-btn-primary:hover { background: var(--pe-primary-dark); }
    .pe-btn-secondary { background: var(--pe-bg-tertiary); color: var(--pe-text-primary); border: 1px solid var(--pe-border); }
    .pe-btn-secondary:hover { background: var(--pe-bg-hover); }
    .pe-btn-ghost { background: transparent; color: var(--pe-text-secondary); }
    .pe-btn-ghost:hover { color: var(--pe-text-primary); background: var(--pe-bg-tertiary); }
    .pe-btn:disabled { opacity: .5; cursor: not-allowed; }

    /* ── Main layout (below header) ─────────────────────────── */
    .pe-main-layout {
        display: flex;
        padding-top: var(--pe-header-h);
        height: 100vh;
    }

    /* ── Sidebar ─────────────────────────────────────────────── */
    .pe-sidebar {
        width: var(--pe-sidebar-w);
        background: var(--pe-bg-secondary);
        border-right: 1px solid var(--pe-border);
        display: flex; flex-direction: column;
        transition: width .3s ease;
        overflow: hidden; flex-shrink: 0;
    }
    .pe-sidebar.collapsed { width: var(--pe-sidebar-coll); }
    .pe-sidebar.pe-sidebar-right { border-right: none; border-left: 1px solid var(--pe-border); }

    .pe-sidebar-header {
        display: flex; align-items: center; gap: 12px;
        padding: 16px;
        border-bottom: 1px solid var(--pe-border);
    }
    .pe-collapse-btn {
        width: 28px; height: 28px;
        display: flex; align-items: center; justify-content: center;
        background: var(--pe-bg-tertiary);
        border: none; border-radius: var(--pe-radius-sm);
        color: var(--pe-text-secondary); cursor: pointer;
        transition: all .2s; flex-shrink: 0;
    }
    .pe-collapse-btn:hover { background: var(--pe-bg-hover); color: var(--pe-text-primary); }
    .pe-sidebar:not(.pe-sidebar-right).collapsed .pe-collapse-btn svg { transform: rotate(180deg); }
    .pe-sidebar.pe-sidebar-right:not(.collapsed) .pe-collapse-btn svg { transform: rotate(180deg); }
    .pe-sidebar-title { font-size: 14px; font-weight: 600; color: var(--pe-text-primary); }

    .pe-sidebar-content { flex: 1; overflow-y: auto; padding: 8px; }

    /* category */
    .pe-category { margin-bottom: 4px; }
    .pe-category-header {
        width: 100%; display: flex; align-items: center; gap: 10px;
        padding: 10px 12px;
        background: transparent; border: none;
        border-radius: var(--pe-radius-md);
        color: var(--pe-text-secondary);
        font-size: 13px; font-weight: 600;
        text-transform: uppercase; letter-spacing: .5px;
        cursor: pointer; transition: all .2s; font-family: inherit;
    }
    .pe-category-header:hover { background: var(--pe-bg-tertiary); color: var(--pe-text-primary); }
    .pe-category-header svg:first-child { color: var(--pe-primary-light); }
    .pe-chevron { margin-left: auto; transition: transform .2s; }
    .pe-chevron.rotated { transform: rotate(180deg); }
    .pe-category-items { padding: 4px 0 4px 8px; }

    .pe-block-item {
        width: 100%; display: flex; align-items: center; gap: 10px;
        padding: 8px 12px;
        background: transparent; border: none;
        border-radius: var(--pe-radius-md);
        color: var(--pe-text-secondary);
        font-size: 13px; cursor: pointer; transition: all .2s; font-family: inherit;
    }
    .pe-block-item:hover { background: var(--pe-bg-tertiary); color: var(--pe-text-primary); }
    .pe-block-item svg { color: var(--pe-text-muted); }
    .pe-block-item:hover svg { color: var(--pe-primary-light); }

    /* ── Editor area ─────────────────────────────────────────── */
    .pe-editor-area {
        flex: 1; display: flex; flex-direction: column;
        overflow: hidden; background: var(--pe-bg-primary);
    }
    .pe-editor-area.preview-mode { background: #fff; }

    /* page header / meta */
    .pe-page-header {
        padding: 24px 32px;
        border-bottom: 1px solid var(--pe-border);
        background: var(--pe-bg-secondary);
        flex-shrink: 0;
    }
    .pe-page-title-input {
        width: 100%; font-size: 28px; font-weight: 700;
        color: var(--pe-text-primary);
        background: transparent; border: none; outline: none; margin-bottom: 12px;
        font-family: inherit;
    }
    .pe-page-title-input::placeholder { color: var(--pe-text-muted); }
    .pe-page-meta { display: flex; justify-content: space-between; align-items: center; }
    .pe-meta-left { display: flex; gap: 20px; }
    .pe-meta-right { display: flex; gap: 8px; }
    .pe-meta-item {
        display: flex; align-items: center; gap: 6px;
        font-size: 13px; color: var(--pe-text-muted);
    }
    .pe-meta-item svg { color: var(--pe-text-secondary); }

    /* preview header */
    .pe-preview-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 24px;
        background: var(--pe-bg-secondary);
        border-bottom: 1px solid var(--pe-border);
        flex-shrink: 0;
    }
    .pe-preview-devices {
        display: flex; gap: 4px;
        background: var(--pe-bg-tertiary);
        padding: 4px; border-radius: var(--pe-radius-md);
    }
    .pe-device-btn {
        padding: 8px 12px;
        background: transparent; border: none;
        border-radius: var(--pe-radius-sm);
        color: var(--pe-text-muted); cursor: pointer; transition: all .2s;
    }
    .pe-device-btn:hover { color: var(--pe-text-primary); }
    .pe-device-btn.active { background: var(--pe-bg-hover); color: var(--pe-text-primary); }

    /* ── Blocks container ────────────────────────────────────── */
    .pe-blocks-container {
        flex: 1; overflow-y: auto;
        padding: 24px 32px;
        max-width: 900px; margin: 0 auto; width: 100%;
    }
    .pe-blocks-container.preview-desktop { max-width: 100%; }
    .pe-blocks-container.preview-tablet  { max-width: 768px; }
    .pe-blocks-container.preview-mobile  { max-width: 375px; }

    .pe-empty-state {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 80px 40px; color: var(--pe-text-muted); text-align: center;
    }
    .pe-empty-state svg { margin-bottom: 20px; color: var(--pe-bg-tertiary); }
    .pe-empty-state h3 { font-size: 20px; font-weight: 600; color: var(--pe-text-secondary); margin-bottom: 8px; }
    .pe-empty-state p  { font-size: 14px; }

    /* ── Block wrapper ───────────────────────────────────────── */
    .pe-block-wrapper {
        position: relative; margin-bottom: 16px;
        border-radius: var(--pe-radius-lg); transition: all .2s;
    }
    .pe-block-wrapper:not(.selected):hover { background: var(--pe-bg-secondary); }
    .pe-block-wrapper.selected  { background: var(--pe-bg-secondary); box-shadow: 0 0 0 2px var(--pe-primary); }
    .pe-block-wrapper.dragging  { opacity: .5; }
    .pe-block-wrapper.drag-over { border: 2px dashed var(--pe-primary); }

    /* block toolbar */
    .pe-block-toolbar {
        position: absolute; top: -12px; right: 12px;
        display: flex; gap: 4px; padding: 4px;
        background: var(--pe-bg-tertiary);
        border-radius: var(--pe-radius-md);
        box-shadow: var(--pe-shadow-md); z-index: 10;
    }
    .pe-toolbar-btn {
        width: 28px; height: 28px;
        display: flex; align-items: center; justify-content: center;
        background: transparent; border: none;
        border-radius: var(--pe-radius-sm);
        color: var(--pe-text-secondary); cursor: pointer; transition: all .2s;
    }
    .pe-toolbar-btn:hover:not(:disabled) { background: var(--pe-bg-hover); color: var(--pe-text-primary); }
    .pe-toolbar-btn:disabled { opacity: .3; cursor: not-allowed; }
    .pe-toolbar-btn.delete:hover { background: var(--pe-error); color: #fff; }

    /* block content */
    .pe-block-content { padding: 16px; }

    /* ── Block types ─────────────────────────────────────────── */

    /* hero */
    .pe-hero-block {
        position: relative; min-height: 400px;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, var(--pe-bg-tertiary) 0%, var(--pe-bg-secondary) 100%);
        background-size: cover; background-position: center;
        border-radius: var(--pe-radius-lg); overflow: hidden; padding: 48px;
    }
    .pe-hero-overlay { position: absolute; inset: 0; background: rgba(15,23,42,.7); }
    .pe-hero-content  { position: relative; z-index: 1; text-align: center; max-width: 700px; width: 100%; }
    .pe-hero-title {
        width: 100%; font-size: 42px; font-weight: 700;
        color: var(--pe-text-primary); background: transparent;
        border: none; text-align: center; margin-bottom: 16px; outline: none; font-family: inherit;
    }
    .pe-hero-title::placeholder  { color: var(--pe-text-muted); }
    .pe-hero-subtitle {
        width: 100%; font-size: 18px;
        color: var(--pe-text-secondary); background: transparent;
        border: none; text-align: center; margin-bottom: 32px; outline: none; font-family: inherit;
    }
    .pe-hero-subtitle::placeholder { color: var(--pe-text-muted); }
    .pe-hero-cta-row { display: flex; gap: 12px; justify-content: center; margin-bottom: 24px; }
    .pe-hero-cta-text, .pe-hero-cta-url {
        padding: 12px 16px;
        background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-md);
        color: var(--pe-text-primary); font-size: 14px; outline: none; font-family: inherit;
    }
    .pe-hero-cta-text { min-width: 150px; }
    .pe-hero-cta-url  { min-width: 200px; color: var(--pe-text-secondary); }
    .pe-hero-cta-text::placeholder, .pe-hero-cta-url::placeholder { color: var(--pe-text-muted); }
    .pe-hero-bg-controls { display: flex; justify-content: center; gap: 12px; }

    /* text block */
    .pe-text-block textarea {
        width: 100%; min-height: 120px; padding: 12px;
        background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-md);
        color: var(--pe-text-primary); font-size: 15px; line-height: 1.6;
        resize: vertical; outline: none; transition: all .2s; font-family: inherit;
    }
    .pe-text-block textarea:focus  { border-color: var(--pe-primary); }
    .pe-text-block textarea::placeholder { color: var(--pe-text-muted); }

    /* rich text (RadzenHtmlEditor will render inside) */
    .pe-content-block { min-height: 200px; }

    /* markdown */
    .pe-markdown-block {
        background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-md); overflow: hidden;
    }
    .pe-markdown-tabs { display: flex; border-bottom: 1px solid var(--pe-border); }
    .pe-tab-btn {
        padding: 10px 16px; background: transparent; border: none;
        color: var(--pe-text-muted); font-size: 13px; font-weight: 500;
        cursor: pointer; transition: all .2s; font-family: inherit;
    }
    .pe-tab-btn:hover { color: var(--pe-text-primary); }
    .pe-tab-btn.active { color: var(--pe-primary-light); border-bottom: 2px solid var(--pe-primary); }
    .pe-markdown-block textarea {
        width: 100%; min-height: 200px; padding: 16px;
        background: transparent; border: none;
        color: var(--pe-text-primary); font-family: 'Monaco','Menlo',monospace;
        font-size: 14px; line-height: 1.6; resize: vertical; outline: none;
    }
    .pe-markdown-preview {
        padding: 16px; min-height: 200px;
        color: var(--pe-text-secondary);
    }
    .pe-markdown-preview h1,.pe-markdown-preview h2,.pe-markdown-preview h3,.pe-markdown-preview h4 { margin-bottom:16px; color:var(--pe-text-primary); }
    .pe-markdown-preview p  { margin-bottom: 12px; }
    .pe-markdown-preview code { background: var(--pe-bg-tertiary); padding: 2px 6px; border-radius: 4px; font-family: monospace; font-size: 13px; }
    .pe-markdown-preview pre { background: var(--pe-bg-tertiary); padding: 16px; border-radius: var(--pe-radius-md); overflow-x: auto; margin-bottom: 16px; }
    .pe-markdown-preview pre code { background: none; padding: 0; }

    /* quote */
    .pe-quote-block {
        padding: 20px 24px;
        border-left: 4px solid var(--pe-primary);
        background: var(--pe-bg-primary);
        border-radius: 0 var(--pe-radius-md) var(--pe-radius-md) 0;
    }
    .pe-quote-block blockquote { margin: 0 0 12px; padding: 0; border: none; }
    .pe-quote-block textarea {
        width: 100%; min-height: 80px;
        background: transparent; border: none;
        color: var(--pe-text-primary); font-size: 18px; font-style: italic;
        line-height: 1.5; resize: vertical; outline: none; font-family: inherit;
    }
    .pe-quote-block textarea::placeholder { color: var(--pe-text-muted); }
    .pe-quote-author {
        width: 100%; padding: 8px 0;
        background: transparent; border: none;
        border-top: 1px solid var(--pe-border);
        color: var(--pe-text-muted); font-size: 14px; outline: none; font-family: inherit;
    }
    .pe-quote-author::placeholder { color: var(--pe-text-muted); }

    /* separator */
    .pe-separator-block { border: none; border-top: 2px solid var(--pe-border); margin: 24px 0; }

    /* columns */
    .pe-columns-block-wrapper { position: relative; }
    .pe-columns-controls {
        display: flex; gap: 24px; padding: 12px 16px;
        background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-md); margin-bottom: 16px;
    }
    .pe-col-ctrl { display: flex; flex-direction: column; gap: 8px; }
    .pe-col-ctrl label { font-size: 12px; color: var(--pe-text-muted); font-weight: 500; }
    .pe-col-ctrl input[type=range] { width: 120px; accent-color: var(--pe-primary); }
    .pe-columns-block { display: flex; flex-wrap: wrap; }
    .pe-column {
        min-width: 0;
        background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-md); padding: 12px; transition: all .2s;
    }
    .pe-column:hover { border-color: var(--pe-border-light); }
    .pe-column-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 12px; padding-bottom: 8px;
        border-bottom: 1px solid var(--pe-border);
    }
    .pe-column-label { font-size: 11px; font-weight: 600; color: var(--pe-text-muted); text-transform: uppercase; letter-spacing: .5px; }
    .pe-column-add-btn {
        width: 20px; height: 20px;
        display: flex; align-items: center; justify-content: center;
        background: var(--pe-bg-tertiary); border: none;
        border-radius: var(--pe-radius-sm); color: var(--pe-text-secondary);
        cursor: pointer; transition: all .2s;
    }
    .pe-column-add-btn:hover { background: var(--pe-primary); color: #fff; }
    .pe-column-content { min-height: 100px; }
    .pe-column-drop-hint {
        display: flex; align-items: center; justify-content: center;
        height: 80px; border: 2px dashed var(--pe-border);
        border-radius: var(--pe-radius-md); color: var(--pe-text-muted); font-size: 12px;
    }

    /* nested blocks */
    .pe-nested-block {
        position: relative; margin-bottom: 12px; padding: 8px;
        background: var(--pe-bg-secondary); border-radius: var(--pe-radius-sm);
    }
    .pe-nested-block textarea {
        width: 100%; min-height: 60px; padding: 8px;
        background: var(--pe-bg-primary); border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-sm); color: var(--pe-text-primary);
        font-size: 13px; resize: vertical; outline: none; font-family: inherit;
    }
    .pe-nested-block textarea:focus { border-color: var(--pe-primary); }
    .pe-nested-image {
        aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;
        background: var(--pe-bg-tertiary); border-radius: var(--pe-radius-sm); overflow: hidden;
    }
    .pe-nested-image img { width: 100%; height: 100%; object-fit: cover; }
    .pe-add-nested-btn {
        display: flex; align-items: center; justify-content: center;
        width: 100%; height: 100%; background: transparent;
        border: 2px dashed var(--pe-border); border-radius: var(--pe-radius-sm);
        color: var(--pe-text-muted); cursor: pointer; transition: all .2s;
    }
    .pe-add-nested-btn:hover { border-color: var(--pe-primary); color: var(--pe-primary-light); }
    .pe-nested-video input {
        width: 100%; padding: 8px; background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border); border-radius: var(--pe-radius-sm);
        color: var(--pe-text-primary); font-size: 13px; outline: none; font-family: inherit;
    }
    .pe-nested-video iframe { width: 100%; aspect-ratio: 16/9; border-radius: var(--pe-radius-sm); }
    .pe-nested-button-editor { display: flex; flex-direction: column; gap: 8px; }
    .pe-nested-button-editor input, .pe-nested-button-editor select {
        padding: 8px; background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border); border-radius: var(--pe-radius-sm);
        color: var(--pe-text-primary); font-size: 13px; outline: none; font-family: inherit;
    }
    .pe-remove-nested-btn {
        position: absolute; top: -6px; right: -6px;
        width: 20px; height: 20px;
        display: flex; align-items: center; justify-content: center;
        background: var(--pe-error); border: none; border-radius: 50%;
        color: #fff; cursor: pointer; opacity: 0; transition: opacity .2s;
    }
    .pe-nested-block:hover .pe-remove-nested-btn { opacity: 1; }

    /* image block */
    .pe-image-block .pe-add-media-btn {
        width: 100%; padding: 48px;
        display: flex; flex-direction: column; align-items: center; gap: 12px;
        background: var(--pe-bg-primary); border: 2px dashed var(--pe-border);
        border-radius: var(--pe-radius-lg); color: var(--pe-text-muted);
        cursor: pointer; transition: all .2s; font-family: inherit;
    }
    .pe-image-block .pe-add-media-btn:hover { border-color: var(--pe-primary); color: var(--pe-primary-light); }
    .pe-image-wrapper { position: relative; }
    .pe-image-wrapper img { width: 100%; border-radius: var(--pe-radius-md); display: block; }
    .pe-image-overlay {
        position: absolute; top: 0; left: 0; right: 0; bottom: 48px;
        display: flex; align-items: center; justify-content: center; gap: 12px;
        background: rgba(15,23,42,.8); opacity: 0; transition: opacity .2s;
        border-radius: var(--pe-radius-md);
    }
    .pe-image-wrapper:hover .pe-image-overlay { opacity: 1; }
    .pe-overlay-btn {
        padding: 8px 16px; background: var(--pe-bg-tertiary); border: none;
        border-radius: var(--pe-radius-md); color: var(--pe-text-primary);
        font-size: 13px; cursor: pointer; transition: all .2s; font-family: inherit;
    }
    .pe-overlay-btn:hover { background: var(--pe-bg-hover); }
    .pe-overlay-btn.delete:hover { background: var(--pe-error); }
    .pe-image-caption {
        width: 100%; margin-top: 12px; padding: 8px 12px;
        background: var(--pe-bg-primary); border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-md); color: var(--pe-text-secondary);
        font-size: 13px; text-align: center; outline: none; font-family: inherit;
    }
    .pe-image-caption:focus { border-color: var(--pe-primary); }

    /* video block */
    .pe-video-block .pe-video-input { display: flex; gap: 12px; }
    .pe-video-block .pe-video-input input {
        flex: 1; padding: 12px 16px; background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border); border-radius: var(--pe-radius-md);
        color: var(--pe-text-primary); font-size: 14px; outline: none; font-family: inherit;
    }
    .pe-video-block .pe-video-input input:focus { border-color: var(--pe-primary); }
    .pe-video-block .pe-video-input input::placeholder { color: var(--pe-text-muted); }
    .pe-video-wrapper {
        position: relative; padding-bottom: 56.25%;
        background: var(--pe-bg-primary); border-radius: var(--pe-radius-md); overflow: hidden;
    }
    .pe-video-wrapper iframe { position: absolute; top:0; left:0; width:100%; height:100%; border:none; }
    .pe-remove-video {
        position: absolute; top: 12px; right: 12px;
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        background: var(--pe-bg-tertiary); border: none;
        border-radius: var(--pe-radius-md); color: var(--pe-text-secondary);
        cursor: pointer; transition: all .2s; z-index: 10;
    }
    .pe-remove-video:hover { background: var(--pe-error); color: #fff; }

    /* gallery */
    .pe-gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 12px;
    }
    .pe-gallery-item { position: relative; aspect-ratio: 1; border-radius: var(--pe-radius-md); overflow: hidden; }
    .pe-gallery-item img { width:100%; height:100%; object-fit:cover; display:block; }
    .pe-remove-item {
        position: absolute; top: 6px; right: 6px;
        width: 24px; height: 24px;
        display: flex; align-items: center; justify-content: center;
        background: var(--pe-error); border: none; border-radius: 50%;
        color: #fff; cursor: pointer; opacity:0; transition: opacity .2s;
    }
    .pe-gallery-item:hover .pe-remove-item { opacity: 1; }
    .pe-add-gallery-item {
        aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
        background: var(--pe-bg-primary); border: 2px dashed var(--pe-border);
        border-radius: var(--pe-radius-md); color: var(--pe-text-muted);
        cursor: pointer; transition: all .2s;
    }
    .pe-add-gallery-item:hover { border-color: var(--pe-primary); color: var(--pe-primary-light); }

    /* audio */
    .pe-audio-block .pe-add-media-btn {
        width: 100%; padding: 48px;
        display: flex; flex-direction: column; align-items: center; gap: 12px;
        background: var(--pe-bg-primary); border: 2px dashed var(--pe-border);
        border-radius: var(--pe-radius-lg); color: var(--pe-text-muted);
        cursor: pointer; transition: all .2s; font-family: inherit;
    }
    .pe-audio-block .pe-add-media-btn:hover { border-color: var(--pe-primary); color: var(--pe-primary-light); }
    .pe-audio-wrapper { display: flex; gap: 12px; align-items: center; }
    .pe-remove-audio {
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        background: var(--pe-bg-tertiary); border: none;
        border-radius: var(--pe-radius-md); color: var(--pe-text-secondary);
        cursor: pointer; transition: all .2s;
    }
    .pe-remove-audio:hover { background: var(--pe-error); color: #fff; }

    /* reference block */
    .pe-reference-block {
        padding: 20px;
        background: var(--pe-bg-primary);
        border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-md);
    }
    .pe-reference-header {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 12px;
        color: var(--pe-text-secondary); font-weight: 600;
    }
    .pe-reference-block select {
        width: 100%; padding: 10px 12px;
        background: var(--pe-bg-secondary);
        border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-md);
        color: var(--pe-text-primary); font-size: 14px; outline: none; font-family: inherit;
    }
    .pe-reference-card {
        margin-top: 12px; padding: 12px;
        background: var(--pe-bg-secondary);
        border-radius: var(--pe-radius-md);
    }
    .pe-reference-card h4 { color: var(--pe-text-primary); font-size: 15px; margin-bottom: 4px; }
    .pe-reference-type { font-size: 12px; color: var(--pe-primary-light); text-transform: capitalize; }
    .pe-author-card { display: flex; align-items: center; gap: 12px; }
    .pe-author-avatar {
        width: 40px; height: 40px; border-radius: 50%;
        background: var(--pe-primary); color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 16px; font-weight: 700;
    }
    .pe-tag-name {
        display: inline-block; padding: 4px 10px;
        background: rgba(99,102,241,.15); color: var(--pe-primary-light);
        border-radius: 99px; font-size: 13px;
    }

    /* add-block FAB */
    .pe-add-block-fab {
        display: flex; align-items: center; justify-content: center;
        width: 48px; height: 48px; margin: 16px auto;
        background: var(--pe-primary); border: none; border-radius: 50%;
        color: #fff; cursor: pointer;
        box-shadow: var(--pe-shadow-md); transition: all .2s;
    }
    .pe-add-block-fab:hover { background: var(--pe-primary-dark); transform: scale(1.05); }

    /* ── Media modal ─────────────────────────────────────────── */
    .pe-modal-overlay {
        position: fixed; inset: 0; z-index: 2000;
        background: rgba(0,0,0,.7);
        display: flex; align-items: center; justify-content: center;
    }
    .pe-modal {
        background: var(--pe-bg-secondary);
        border: 1px solid var(--pe-border);
        border-radius: var(--pe-radius-lg);
        width: 800px; max-width: 95vw; max-height: 90vh;
        display: flex; flex-direction: column;
        overflow: hidden;
    }
    .pe-modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 24px;
        border-bottom: 1px solid var(--pe-border);
    }
    .pe-modal-header h3 { font-size: 18px; font-weight: 600; color: var(--pe-text-primary); margin: 0; }
    .pe-modal-close {
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        background: transparent; border: none;
        border-radius: var(--pe-radius-sm); color: var(--pe-text-secondary);
        cursor: pointer; transition: all .2s;
    }
    .pe-modal-close:hover { background: var(--pe-bg-tertiary); color: var(--pe-text-primary); }
    .pe-modal-tabs { display: flex; border-bottom: 1px solid var(--pe-border); padding: 0 24px; }
    .pe-modal-body { flex: 1; overflow-y: auto; padding: 24px; }
    .pe-modal-footer {
        display: flex; justify-content: flex-end; gap: 12px;
        padding: 16px 24px; border-top: 1px solid var(--pe-border);
    }
    .pe-media-gallery { display: grid; grid-template-columns: repeat(auto-fill,minmax(140px,1fr)); gap: 12px; }
    .pe-media-item {
        position: relative; aspect-ratio: 1;
        border-radius: var(--pe-radius-md); overflow: hidden; cursor: pointer;
        border: 2px solid transparent; transition: all .2s;
    }
    .pe-media-item img { width:100%; height:100%; object-fit:cover; display:block; }
    .pe-media-item.selected { border-color: var(--pe-primary); }
    .pe-media-check {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center;
        background: rgba(99,102,241,.4);
        color: #fff;
    }
    .pe-upload-dropzone {
        border: 2px dashed var(--pe-border);
        border-radius: var(--pe-radius-lg);
        padding: 60px 40px; text-align: center;
        color: var(--pe-text-muted); cursor: pointer; transition: all .2s;
    }
    .pe-upload-dropzone:hover { border-color: var(--pe-primary); color: var(--pe-primary-light); }
    .pe-upload-dropzone svg { margin-bottom: 16px; }
    .pe-upload-dropzone p { margin-bottom: 8px; font-size: 15px; }
    .pe-upload-dropzone span { font-size: 13px; display: block; margin-bottom: 16px; }

    /* ── Toast container ─────────────────────────────────────── */
    .pe-toast-container {
        position: fixed; bottom: 24px; right: 24px;
        display: flex; flex-direction: column; gap: 8px; z-index: 9999;
    }
    .pe-toast {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 16px; border-radius: var(--pe-radius-md);
        background: var(--pe-bg-tertiary); color: var(--pe-text-primary);
        font-size: 14px; cursor: pointer;
        box-shadow: var(--pe-shadow-lg);
        animation: pe-toast-in .3s ease;
    }
    .pe-toast.success { background: #16a34a; }
    .pe-toast.error   { background: var(--pe-error); }
    .pe-toast.info    { background: var(--pe-info); }
    @@keyframes pe-toast-in {
        from { opacity: 0; transform: translateX(20px); }
        to   { opacity: 1; transform: translateX(0); }
    }
</style>

