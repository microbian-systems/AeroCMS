<Project>
	<PropertyGroup>
		<!--
      Skip TargetFramework for MAUI projects — they self-define multi-targeted
      TargetFrameworks (net10.0-android, net10.0-ios, net10.0-maccatalyst, etc.)
      and setting this would clobber that.
    -->
		<TargetFramework
			Condition="'$(UseMaui)' != 'true' AND
                 '$(ManageTargetFrameworkIndependently)' != 'true' AND
                 '$(TargetFrameworks)' == ''">net10.0</TargetFramework>

		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<PropertyGroup Label="Package information">
		<Version>0.0.5-alpha</Version>
		<Authors>Aero Cms</Authors>
		<Company>Microbian Systems</Company>
		<Copyright>Copyright (c) 2025 Microbians</Copyright>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageTags>cms mvc razorpages aspnetcore</PackageTags>
		<PackageIcon>../Aero.png</PackageIcon>
		<PackageProjectUrl>https://github.com/microbian-systems/Aero.core</PackageProjectUrl>
		<RepositoryUrl>https://github.com/microbian-systems/Aero.core</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<IncludeSymbols>true</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
		<EmbedUntrackedSources>true</EmbedUntrackedSources>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
	</PropertyGroup>

	<ItemGroup Condition="'$(MSBuildProjectName)' != 'Aero.Cms.Web.Core' AND '$(MSBuildProjectName)' != 'Aero.Cms.Core' AND ($(MSBuildProjectName.StartsWith('Aero.Cms.Modules')) OR $(MSBuildProjectName.StartsWith('Aero.Cms.Banners')) OR $(MSBuildProjectName.StartsWith('Aero.Cms.CookiePolicy')))">
		<ProjectReference Include="$(MSBuildThisFileDirectory)Aero.Cms.Web.Core\Aero.Cms.Web.Core.csproj" />
	</ItemGroup>
</Project>