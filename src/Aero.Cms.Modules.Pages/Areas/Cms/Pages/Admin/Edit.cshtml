@page "/admin/pages/edit/{id?}"
@page "/admin/pages/create"
@using Aero.Cms.Modules.Pages
@using Aero.Cms.Modules.Pages.Models

@model global::Aero.Cms.Modules.Pages.Areas.Cms.Pages.Admin.EditModel

@{
    ViewBag.Title = Model.IsNew ? "Create Page" : "Edit Page";
}

<div class="min-h-screen bg-slate-50">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-slate-900">
                    @(Model.IsNew ? "Create New Page" : "Edit Page")
                </h1>
                <p class="mt-2 text-sm text-slate-600">
                    @(Model.IsNew ? "Create a new page for your site" : "Update your page content and settings")
                </p>
            </div>
            <a href="/admin/pages" 
               class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 transition-colors hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2">
                <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Pages
            </a>
        </div>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-6 rounded-lg border border-red-200 bg-red-50 p-4">
                <div class="flex items-center gap-3">
                    <svg class="h-5 w-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-sm font-medium text-red-800">@Model.ErrorMessage</span>
                </div>
            </div>
        }

        <!-- Page Form -->
        <form method="post" class="space-y-6">
            <input type="hidden" asp-for="PageDocument!.Id" />
            <input type="hidden" asp-for="PageDocument!.Kind" />
            <input type="hidden" asp-for="PageDocument!.PublicationState" />
            <input type="hidden" asp-for="PageDocument!.PublishedOn" />
            
            <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
                <!-- Main Content Column -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Basic Info Card -->
                    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 bg-slate-50 px-6 py-4">
                            <h2 class="text-lg font-semibold text-slate-900">Page Details</h2>
                            <p class="mt-1 text-sm text-slate-600">Basic information about the page</p>
                        </div>
                        <div class="p-6 space-y-6">
                            <!-- Title -->
                            <div>
                                <label asp-for="PageDocument!.Title" class="block text-sm font-medium text-slate-900">
                                    Page Title
                                </label>
                                <input asp-for="PageDocument!.Title" 
                                       class="mt-2 block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-cyan-600 sm:text-sm"
                                       placeholder="Enter page title" />
                                <span asp-validation-for="PageDocument!.Title" class="mt-2 text-sm text-red-600"></span>
                            </div>

                            <!-- Slug -->
                            <div>
                                <label asp-for="PageDocument!.Slug" class="block text-sm font-medium text-slate-900">
                                    Slug (URL)
                                </label>
                                <div class="mt-2 flex rounded-lg shadow-sm">
                                    <span class="inline-flex items-center rounded-l-lg border border-r-0 border-slate-300 bg-slate-50 px-3 text-sm text-slate-500">
                                        /
                                    </span>
                                    <input asp-for="PageDocument!.Slug" 
                                           class="block w-full rounded-none rounded-r-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-cyan-600 sm:text-sm"
                                           placeholder="page-slug" />
                                </div>
                                <p class="mt-2 text-xs text-slate-500">The URL-friendly identifier for this page</p>
                                <span asp-validation-for="PageDocument!.Slug" class="mt-2 text-sm text-red-600"></span>
                            </div>

                            <!-- Summary -->
                            <div>
                                <label asp-for="PageDocument!.Summary" class="block text-sm font-medium text-slate-900">
                                    Summary
                                </label>
                                <textarea asp-for="PageDocument!.Summary" 
                                          rows="3"
                                          class="mt-2 block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-cyan-600 sm:text-sm"
                                          placeholder="Brief description of the page"></textarea>
                                <p class="mt-2 text-xs text-slate-500">A short summary shown in listings and previews</p>
                                <span asp-validation-for="PageDocument!.Summary" class="mt-2 text-sm text-red-600"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Content Card -->
                    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 bg-slate-50 px-6 py-4">
                            <h2 class="text-lg font-semibold text-slate-900">Page Content</h2>
                            <p class="mt-1 text-sm text-slate-600">Main content for the page</p>
                        </div>
                        <div class="p-6">
                            <component type="typeof(RadzenHtmlEditor)" 
                                       render-mode="ServerPrerendered"
                                       param-Value="Model.PageDocument!.LayoutRegions.FirstOrDefault()?.Blocks.FirstOrDefault()?.Content"
                                       param-Style=""margin-bottom: 1rem;"" />
                            <p class="mt-2 text-xs text-slate-500">Use the rich text editor to format your content</p>
                        </div>
                    </div>

                    <!-- Block Composition -->
                    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 bg-slate-50 px-6 py-4">
                            <h2 class="text-lg font-semibold text-slate-900">Content Blocks</h2>
                            <p class="mt-1 text-sm text-slate-600">Manage page content blocks</p>
                        </div>
                        <div class="p-6">
                            @if (Model.ShowBlockPicker)
                            {
                                <!-- Block Picker -->
                                <div class="mb-4">
                                    <form method="get" asp-page-handler="CancelBlockEditing" class="mb-4">
                                        <button type="submit" class="inline-flex items-center gap-2 text-sm text-slate-600 hover:text-slate-900">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                                            </svg>
                                            Back to blocks
                                        </button>
                                    </form>
                                    <component type="typeof(Aero.Cms.Modules.Admin.Components.BlockPicker)"
                                               render-mode="ServerPrerendered"
                                               param-OnBlockTypeSelected="Model.OnBlockTypeSelected"
                                               param-OnCancel="Model.OnCancelBlockPicker" />
                                </div>
                            }
                            else if (Model.ShowBlockEditor && Model.SelectedBlock != null)
                            {
                                <!-- Block Editor -->
                                <div class="mb-4">
                                    <form method="get" asp-page-handler="CancelBlockEditing" class="mb-4">
                                        <button type="submit" class="inline-flex items-center gap-2 text-sm text-slate-600 hover:text-slate-900">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                                            </svg>
                                            Back to blocks
                                        </button>
                                    </form>
                                    <component type="typeof(Aero.Cms.Modules.Admin.Components.BlockEditor)"
                                               render-mode="ServerPrerendered"
                                               param-Block="Model.SelectedBlock"
                                               param-OnSave="Model.OnBlockSave"
                                               param-OnCancel="Model.OnBlockCancel"
                                               param-OnDelete="Model.OnBlockDelete"
                                               param-OnDuplicate="Model.OnBlockDuplicate"
                                               param-OnMoveUp="Model.OnBlockMoveUp"
                                               param-OnMoveDown="Model.OnBlockMoveDown"
                                               param-CanMoveUp="Model.CanMoveBlockUp"
                                               param-CanMoveDown="Model.CanMoveBlockDown" />
                                </div>
                            }
                            else
                            {
                                <!-- Block List -->
                                <div class="space-y-4">
                                    @if (Model.PageDocument?.LayoutRegions != null && Model.PageDocument.LayoutRegions.Any())
                                    {
                                        foreach (var region in Model.PageDocument.LayoutRegions.OrderBy(r => r.Order))
                                        {
                                            if (region.Columns != null && region.Columns.Any())
                                            {
                                                foreach (var column in region.Columns.OrderBy(c => c.Order))
                                                {
                                                    if (column.Blocks != null && column.Blocks.Any())
                                                    {
                                                        foreach (var placement in column.Blocks.OrderBy(b => b.Order))
                                                        {
                                                            <div class="flex items-center gap-4 rounded-lg border border-slate-200 bg-white p-4 transition-shadow hover:shadow-md">
                                                                <div class="flex-shrink-0">
                                                                    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-cyan-500 to-blue-600 text-white">
                                                                        @switch (placement.BlockType?.ToLowerInvariant())
                                                                        {
                                                                            case "rich_text":
                                                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
                                                                                </svg>
                                                                                break;
                                                                            case "heading":
                                                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
                                                                                </svg>
                                                                                break;
                                                                            case "image":
                                                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                                                                </svg>
                                                                                break;
                                                                            case "cta":
                                                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
                                                                                </svg>
                                                                                break;
                                                                            case "quote":
                                                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                                                                                </svg>
                                                                                break;
                                                                            case "embed":
                                                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                                                                                </svg>
                                                                                break;
                                                                            default:
                                                                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                                                                </svg>
                                                                                break;
                                                                        }
                                                                    </div>
                                                                </div>
                                                                <div class="flex-1 min-w-0">
                                                                    <h4 class="text-sm font-semibold text-slate-900 truncate">
                                                                        @placement.BlockType switch {
                                                                            "rich_text" => "Rich Text",
                                                                            "heading" => "Heading",
                                                                            "image" => "Image",
                                                                            "cta" => "Call to Action",
                                                                            "quote" => "Quote",
                                                                            "embed" => "Embed",
                                                                            _ => placement.BlockType
                                                                        }
                                                                    </h4>
                                                                    <p class="text-xs text-slate-500">Block #@(placement.Order + 1)</p>
                                                                </div>
                                                                <div class="flex items-center gap-2">
                                                                    <!-- Move Up -->
                                                                    @if (placement.Order > 0)
                                                                    {
                                                                        <form method="post" asp-page-handler="MoveBlockUp" class="inline">
                                                                            <input type="hidden" name="blockId" value="@placement.BlockId" />
                                                                            <button type="submit" class="p-1.5 rounded-md text-slate-400 hover:text-slate-600 hover:bg-slate-100" title="Move up">
                                                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                                                                                </svg>
                                                                            </button>
                                                                        </form>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="p-1.5">
                                                                            <svg class="h-4 w-4 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                                                                            </svg>
                                                                        </span>
                                                                    }

                                                                    <!-- Move Down -->
                                                                    @if (column.Blocks.Count > 1 && placement.Order < column.Blocks.Count - 1)
                                                                    {
                                                                        <form method="post" asp-page-handler="MoveBlockDown" class="inline">
                                                                            <input type="hidden" name="blockId" value="@placement.BlockId" />
                                                                            <button type="submit" class="p-1.5 rounded-md text-slate-400 hover:text-slate-600 hover:bg-slate-100" title="Move down">
                                                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                                                                </svg>
                                                                            </button>
                                                                        </form>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="p-1.5">
                                                                            <svg class="h-4 w-4 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                                                            </svg>
                                                                        </span>
                                                                    }

                                                                    <!-- Edit -->
                                                                    <form method="get" asp-page-handler="EditBlock" class="inline">
                                                                        <input type="hidden" name="blockId" value="@placement.BlockId" />
                                                                        <input type="hidden" name="regionName" value="@region.Name" />
                                                                        <input type="hidden" name="columnIndex" value="@column.Order" />
                                                                        <button type="submit" class="p-1.5 rounded-md text-slate-400 hover:text-cyan-600 hover:bg-cyan-50" title="Edit">
                                                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                                            </svg>
                                                                        </button>
                                                                    </form>

                                                                    <!-- Duplicate -->
                                                                    <form method="post" asp-page-handler="DuplicateBlock" class="inline">
                                                                        <input type="hidden" name="blockId" value="@placement.BlockId" />
                                                                        <button type="submit" class="p-1.5 rounded-md text-slate-400 hover:text-blue-600 hover:bg-blue-50" title="Duplicate">
                                                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                                                            </svg>
                                                                        </button>
                                                                    </form>

                                                                    <!-- Delete -->
                                                                    <form method="post" asp-page-handler="DeleteBlock" class="inline" onsubmit="return confirm('Are you sure you want to delete this block?');">
                                                                        <input type="hidden" name="blockId" value="@placement.BlockId" />
                                                                        <button type="submit" class="p-1.5 rounded-md text-slate-400 hover:text-red-600 hover:bg-red-50" title="Delete">
                                                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                                            </svg>
                                                                        </button>
                                                                    </form>
                                                                </div>
                                                            </div>
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-8 text-center">
                                            <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                            </svg>
                                            <h3 class="mt-4 text-sm font-medium text-slate-900">No blocks yet</h3>
                                            <p class="mt-2 text-sm text-slate-500">Get started by adding your first content block</p>
                                        </div>
                                    }

                                    <!-- Add Block Button -->
                                    <form method="get" asp-page-handler="ShowBlockPicker" class="mt-4">
                                        <input type="hidden" name="regionName" value="MainContent" />
                                        <input type="hidden" name="columnIndex" value="0" />
                                        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg border-2 border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-600 transition-colors hover:border-cyan-500 hover:bg-cyan-50 hover:text-cyan-700">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                            </svg>
                                            Add Block
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Sidebar Column -->
                <div class="space-y-6">
                    <!-- SEO Card -->
                    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 bg-slate-50 px-6 py-4">
                            <h2 class="text-lg font-semibold text-slate-900">SEO Settings</h2>
                            <p class="mt-1 text-sm text-slate-600">Search engine optimization</p>
                        </div>
                        <div class="p-6 space-y-6">
                            <!-- SEO Title -->
                            <div>
                                <label asp-for="PageDocument!.SeoTitle" class="block text-sm font-medium text-slate-900">
                                    SEO Title
                                </label>
                                <input asp-for="PageDocument!.SeoTitle" 
                                       class="mt-2 block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-cyan-600 sm:text-sm"
                                       placeholder="Custom title for search engines" />
                                <p class="mt-2 text-xs text-slate-500">Leave empty to use the page title</p>
                                <span asp-validation-for="PageDocument!.SeoTitle" class="mt-2 text-sm text-red-600"></span>
                            </div>

                            <!-- SEO Description -->
                            <div>
                                <label asp-for="PageDocument!.SeoDescription" class="block text-sm font-medium text-slate-900">
                                    SEO Description
                                </label>
                                <textarea asp-for="PageDocument!.SeoDescription" 
                                          rows="4"
                                          class="mt-2 block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-cyan-600 sm:text-sm"
                                          placeholder="Meta description for search results"></textarea>
                                <p class="mt-2 text-xs text-slate-500">Recommended: 150-160 characters</p>
                                <span asp-validation-for="PageDocument!.SeoDescription" class="mt-2 text-sm text-red-600"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Publication Status Card -->
                    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                        <div class="border-b border-slate-200 bg-slate-50 px-6 py-4">
                            <h2 class="text-lg font-semibold text-slate-900">Publication Status</h2>
                        </div>
                        <div class="p-6">
                            <div class="flex items-center justify-between">
                                <span class="text-sm font-medium text-slate-900">Status</span>
                                @if (Model.PageDocument?.PublicationState == ContentPublicationState.Published)
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-600"></span>
                                        Published
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-2.5 py-1 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20">
                                        <span class="h-1.5 w-1.5 rounded-full bg-amber-600"></span>
                                        Draft
                                    </span>
                                }
                            </div>
                            @if (Model.PageDocument?.PublishedOn.HasValue == true)
                            {
                                <p class="mt-2 text-xs text-slate-500">
                                    Published on @Model.PageDocument.PublishedOn.Value.ToString("MMM dd, yyyy")
                                </p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex items-center justify-end gap-4 border-t border-slate-200 pt-6">
                <a href="/admin/pages" 
