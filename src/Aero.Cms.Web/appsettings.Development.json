{
  "Environment": "Development",
  "infisical": {
    "machineId": "b365f11a-dffc-4f81-b5e0-2f8e13a6b162",
    "clientSecret": "9668afce41ecae514b7428963180c0e40f6f67fd256085904fa3d3781f7a9919"
  },
  "AeroHttpClientBaseAddress": "https://localhost:333/api/v1",
  "ConnectionStrings": {
    "aero": "Host=localhost;Port=5433;Username=aero;Password=;Database=aero;"
  },
  "AeroCms": {
    "DataProtection": {
      "KeyStoragePath": "keys",
      "ApplicationName": "AeroCMS",
      "Certificate": {
        "Path": "certs/aero-cms.pfx",
        "Password": null
      }
    },
    "Bootstrap": {
      "State": "Running",
      "SetupComplete": true,
      "SeedComplete": true,
      "DatabaseMode": "Embedded",
      "CacheMode": "Memory",
      "SecretProvider": "Local Certificate",
      "HasBootstrapConfig": true,
      "AuthenticationMode": "Local"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Trace",
      "Microsoft.AspNetCore.Mvc.ModelBinding": "Trace",
      "Microsoft.AspNetCore.Routing": "Trace",
      "Microsoft.AspNetCore.HttpLogging": "Information"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.AspNetCore.Routing": "Debug",
        "Microsoft.AspNetCore.Mvc.Infrastructure.ControllerActionInvoker": "Debug",
        "Microsoft.AspNetCore.Mvc.ViewFeatures.ViewResultExecutor": "Debug",
        "Microsoft.AspNetCore.Mvc.Razor.Internal": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/aero-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "aero-cms"
    }
  }
}