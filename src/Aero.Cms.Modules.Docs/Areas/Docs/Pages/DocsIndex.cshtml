@page "/docs"
@model Aero.Cms.Modules.Docs.Areas.Docs.Pages.DocsIndexModel
@{
    ViewData["Title"] = "Developer Documentation";
}

<div class="min-h-screen bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-50 via-slate-50 to-white">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <!-- Documentation Header -->
        <div class="mb-16 text-center">
            <h1 class="font-display text-5xl font-black tracking-tight text-slate-900 sm:text-7xl">
                Knowledge <span class="text-indigo-600">Base</span>
            </h1>
            <p class="mt-6 text-xl text-slate-600 max-w-2xl mx-auto font-medium leading-relaxed">
                Everything you need to build, extend, and scale with Aero CMS. Our comprehensive guides and API reference help you deliver high-performance digital experiences.
            </p>
        </div>

        @if (Model.Chapters.Any())
        {
            <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
                @foreach (var chapter in Model.Chapters)
                {
                    <div class="group relative flex flex-col p-8 bg-white rounded-[2.5rem] border border-slate-200/60 shadow-xl shadow-slate-200/50 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:border-indigo-100">
                        <!-- Chapter Decorative Icon -->
                        <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-50 text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white group-hover:shadow-lg group-hover:shadow-indigo-300 transition-all duration-300">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                            </svg>
                        </div>

                        <h2 class="mb-4 text-2xl font-extrabold text-slate-900 group-hover:text-indigo-600 transition-colors">
                            <a href="/@chapter.Slug" class="focus:outline-none">
                                <span class="absolute inset-0" aria-hidden="true"></span>
                                @chapter.Title
                            </a>
                        </h2>

                        @if (!string.IsNullOrEmpty(chapter.Summary))
                        {
                            <p class="mb-8 text-base text-slate-500 font-medium leading-relaxed line-clamp-2">
                                @chapter.Summary
                            </p>
                        }

                        <!-- Nested Sections -->
                        @if (Model.Sections.TryGetValue(chapter.Id, out var docSections) && docSections.Any())
                        {
                            <div class="mt-auto space-y-3 pt-6 border-t border-slate-100 relative z-10 pointer-events-auto">
                                @foreach (var docSection in docSections)
                                {
                                    <a href="/@docSection.Slug" class="flex items-center gap-3 text-sm font-bold text-slate-400 hover:text-indigo-600 transition-colors group/link p-1 relative z-20">
                                        <div class="h-1.5 w-1.5 rounded-full bg-slate-200 group-hover/link:bg-indigo-400 group-hover/link:scale-150 transition-all"></div>
                                        @docSection.Title
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="flex flex-col items-center justify-center rounded-[3rem] border-2 border-dashed border-slate-300 bg-white/50 py-24 px-6 text-center">
                <div class="bg-slate-100 p-6 rounded-full inline-block mb-6 shadow-sm">
                    <svg class="h-12 w-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900">No documentation found</h3>
                <p class="mt-2 text-slate-500 font-medium">We're still working on publishing our detailed guides. Check back shortly!</p>
            </div>
        }
    </div>
</div>
